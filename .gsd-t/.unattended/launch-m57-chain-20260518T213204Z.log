{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013Jg1qjEuVPhPfvsNndMjmR","type":"tool_result","content":"1\t'use strict';\n2\t\n3\t/**\n4\t * Tests for bin/gsd-t-ci-parity.cjs (M57 D2)\n5\t *\n6\t * Covers:\n7\t *  - Detection precedence (cloudbuild → workflows → dockerfile-run → package-scripts → none)\n8\t *  - Cache clearing (stale .tsbuildinfo removed before commands run)\n9\t *  - no-dockerfile / docker-unavailable paths (non-failure)\n10\t *  - SC2: planted noImplicitAny regression caught by real docker build (self-skips when no daemon)\n11\t *\n12\t * Contract: .gsd-t/contracts/ci-parity-contract.md v1.0.0 STABLE\n13\t */\n14\t\n15\tconst { test } = require('node:test');\n16\tconst assert = require('node:assert/strict');\n17\tconst fs = require('fs');\n18\tconst path = require('path');\n19\tconst child_process = require('child_process');\n20\t\n21\tconst { runCiParity, detectCi, clearBuildCaches } = require('../bin/gsd-t-ci-parity.cjs');\n22\t\n23\tconst FIXTURES = path.join(__dirname, 'fixtures', 'm57-ci-parity');\n24\t\n25\t// ── Helpers ────────────────────────────────────────────────────────────────────\n26\t\n27\tfunction fixtureDir(name) {\n28\t  return path.join(FIXTURES, name);\n29\t}\n30\t\n31\tfunction isDockerAvailable() {\n32\t  try {\n33\t    const r = child_process.spawnSync('docker', ['info'], {\n34\t      stdio: ['ignore', 'pipe', 'pipe'],\n35\t      timeout: 8000,\n36\t    });\n37\t    return r.status === 0;\n38\t  } catch { return false; }\n39\t}\n40\t\n41\t// ── Detection Precedence Tests ─────────────────────────────────────────────────\n42\t\n43\ttest('detection_cloudbuild_takes_precedence', () => {\n44\t  const d = fixtureDir('cloudbuild');\n45\t  const r = detectCi(d);\n46\t  assert.equal(r.source, 'cloudbuild', 'Should detect cloudbuild source');\n47\t  assert.ok(r.commands.length > 0, 'Should extract commands from cloudbuild.yaml');\n48\t  // cloudbuild.yaml steps[].args are joined with spaces\n49\t  assert.ok(r.commands[0].includes('node'), 'First command should include \"node\"');\n50\t});\n51\t\n52\ttest('detection_workflows_when_no_cloudbuild', () => {\n53\t  const d = fixtureDir('workflows');\n54\t  // Ensure no cloudbuild.yaml in this fixture\n55\t  assert.ok(!fs.existsSync(path.join(d, 'cloudbuild.yaml')), 'Fixture must not have cloudbuild.yaml');\n56\t  const r = detectCi(d);\n57\t  assert.equal(r.source, 'workflows', 'Should detect workflows source');\n58\t  assert.ok(r.commands.length > 0, 'Should extract run commands from workflow yml');\n59\t});\n60\t\n61\ttest('detection_dockerfile_run_when_no_cloudbuild_or_workflows', () => {\n62\t  const d = fixtureDir('dockerfile-run');\n63\t  assert.ok(!fs.existsSync(path.join(d, 'cloudbuild.yaml')), 'Fixture must not have cloudbuild.yaml');\n64\t  assert.ok(!fs.existsSync(path.join(d, '.github')), 'Fixture must not have .github dir');\n65\t  const r = detectCi(d);\n66\t  assert.equal(r.source, 'dockerfile-run', 'Should detect dockerfile-run source');\n67\t  assert.ok(r.commands.length > 0, 'Should extract RUN lines from Dockerfile');\n68\t});\n69\t\n70\ttest('detection_package_scripts_fallback', () => {\n71\t  const d = fixtureDir('pkg-fallback');\n72\t  assert.ok(!fs.existsSync(path.join(d, 'cloudbuild.yaml')), 'Fixture must not have cloudbuild.yaml');\n73\t  assert.ok(!fs.existsSync(path.join(d, '.github')), 'Fixture must not have .github dir');\n74\t  assert.ok(!fs.existsSync(path.join(d, 'Dockerfile')), 'Fixture must not have Dockerfile');\n75\t  const r = detectCi(d);\n76\t  assert.equal(r.source, 'package-scripts', 'Should fall back to package-scripts');\n77\t  assert.ok(r.commands.length > 0, 'Should extract npm run scripts');\n78\t  // Order: build, typecheck, test\n79\t  assert.ok(r.commands[0].includes('build'), 'First script should be build');\n80\t  assert.ok(r.commands[1].includes('typecheck'), 'Second script should be typecheck');\n81\t  assert.ok(r.commands[2].includes('test'), 'Third script should be test');\n82\t});\n83\t\n84\ttest('detection_none_when_no_ci_artifacts', () => {\n85\t  // Use a temp dir with only an empty package.json (no scripts)\n86\t  const tmp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'gsd-t-ci-parity-none-'));\n87\t  try {\n88\t    fs.writeFileSync(path.join(tmp, 'package.json'), JSON.stringify({ name: 'test' }));\n89\t    const r = detectCi(tmp);\n90\t    assert.equal(r.source, 'none', 'Should return none when no CI config found');\n91\t    assert.deepEqual(r.commands, [], 'Should return empty commands array');\n92\t  } finally {\n93\t    fs.rmSync(tmp, { recursive: true, force: true });\n94\t  }\n95\t});\n96\t\n97\ttest('detection_precedence_strict_order_cloudbuild_beats_workflows', () => {\n98\t  // A fixture with both cloudbuild.yaml AND .github/workflows should use cloudbuild\n99\t  const tmp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'gsd-t-ci-parity-prec-'));\n100\t  try {\n101\t    fs.writeFileSync(path.join(tmp, 'cloudbuild.yaml'), [\n102\t      'steps:',\n103\t      \"  - name: 'node:18'\",\n104\t      \"    args: ['node', '-e', 'process.exit(0)']\",\n105\t    ].join('\\n'));\n106\t    const wfDir = path.join(tmp, '.github', 'workflows');\n107\t    fs.mkdirSync(wfDir, { recursive: true });\n108\t    fs.writeFileSync(path.join(wfDir, 'ci.yml'), [\n109\t      'name: CI',\n110\t      'on: [push]',\n111\t      'jobs:',\n112\t      '  build:',\n113\t      '    steps:',\n114\t      '      - run: echo workflows-step',\n115\t    ].join('\\n'));\n116\t    const r = detectCi(tmp);\n117\t    assert.equal(r.source, 'cloudbuild', 'cloudbuild must beat workflows in precedence');\n118\t  } finally {\n119\t    fs.rmSync(tmp, { recursive: true, force: true });\n120\t  }\n121\t});\n122\t\n123\t// ── Cache Clear Tests ──────────────────────────────────────────────────────────\n124\t\n125\ttest('cache_clear_removes_tsbuildinfo', () => {\n126\t  const tmp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'gsd-t-ci-parity-cache-'));\n127\t  try {\n128\t    // Plant a stale .tsbuildinfo file\n129\t    const staleFile = path.join(tmp, 'tsconfig.tsbuildinfo');\n130\t    fs.writeFileSync(staleFile, '{}');\n131\t    assert.ok(fs.existsSync(staleFile), 'Stale file must exist before clear');\n132\t    clearBuildCaches(tmp);\n133\t    assert.ok(!fs.existsSync(staleFile), 'Stale .tsbuildinfo must be removed after clear');\n134\t  } finally {\n135\t    fs.rmSync(tmp, { recursive: true, force: true });\n136\t  }\n137\t});\n138\t\n139\ttest('cache_clear_removes_node_modules_cache', () => {\n140\t  const tmp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'gsd-t-ci-parity-nm-'));\n141\t  try {\n142\t    const cacheDir = path.join(tmp, 'node_modules', '.cache');\n143\t    fs.mkdirSync(cacheDir, { recursive: true });\n144\t    fs.writeFileSync(path.join(cacheDir, 'something.json'), '{}');\n145\t    assert.ok(fs.existsSync(cacheDir), 'Cache dir must exist before clear');\n146\t    clearBuildCaches(tmp);\n147\t    assert.ok(!fs.existsSync(cacheDir), 'node_modules/.cache must be removed after clear');\n148\t  } finally {\n149\t    fs.rmSync(tmp, { recursive: true, force: true });\n150\t  }\n151\t});\n152\t\n153\ttest('cache_clear_removes_tsconfig_tsbuildinffile', () => {\n154\t  const tmp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'gsd-t-ci-parity-tscfg-'));\n155\t  try {\n156\t    // Plant a tsconfig.json with explicit tsBuildInfoFile\n157\t    const buildInfoPath = path.join(tmp, '.tsbuildinfo');\n158\t    fs.writeFileSync(buildInfoPath, '{\"version\":\"stale\"}');\n159\t    fs.writeFileSync(path.join(tmp, 'tsconfig.json'), JSON.stringify({\n160\t      compilerOptions: {\n161\t        incremental: true,\n162\t        tsBuildInfoFile: '.tsbuildinfo',\n163\t        noEmit: true,\n164\t      },\n165\t    }));\n166\t    assert.ok(fs.existsSync(buildInfoPath), 'tsBuildInfoFile must exist before clear');\n167\t    clearBuildCaches(tmp);\n168\t    assert.ok(!fs.existsSync(buildInfoPath), 'tsBuildInfoFile must be removed after clear');\n169\t  } finally {\n170\t    fs.rmSync(tmp, { recursive: true, force: true });\n171\t  }\n172\t});\n173\t\n174\t// ── Docker skip / unavailable Tests ──────────────────────────────────────────\n175\t\n176\ttest('no_dockerfile_skips_docker_non_failure', () => {\n177\t  const d = fixtureDir('pkg-fallback');\n178\t  // pkg-fallback has no Dockerfile — docker should be skipped, not a failure\n179\t  const r = runCiParity({ projectDir: d, timeoutMs: 10000 });\n180\t  assert.equal(r.dockerBuilt, false, 'dockerBuilt must be false when no Dockerfile');\n181\t  assert.equal(r.dockerSkippedReason, 'no-dockerfile', 'dockerSkippedReason must be no-dockerfile');\n182\t});\n183\t\n184\ttest('docker_unavailable_is_not_hard_failure', () => {\n185\t  // Real docker-unavailable path: Dockerfile PRESENT + docker binary absent →\n186\t  // ok:true (not a hard failure), dockerBuilt:false, dockerSkippedReason:'docker-unavailable'.\n187\t  //\n188\t  // Technique: temporarily override process.env.PATH to a nonexistent directory\n189\t  // so that spawnSync('docker', ...) in dockerAvailable() throws ENOENT → returns false.\n190\t  const tmp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'gsd-t-ci-parity-docker-'));\n191\t  const origPath = process.env.PATH;\n192\t  try {\n193\t    // A Dockerfile with no RUN lines so detectCi falls back to package-scripts.\n194\t    // We add a passing package.json script so command execution succeeds.\n195\t    fs.writeFileSync(path.join(tmp, 'Dockerfile'), 'FROM scratch\\nCOPY . .\\n');\n196\t    fs.writeFileSync(path.join(tmp, 'package.json'), JSON.stringify({\n197\t      name: 'test-docker-unavail',\n198\t      scripts: { build: 'node -e \"process.exit(0)\"' },\n199\t    }));\n200\t\n201\t    // Point PATH at a directory that has no binaries (docker binary unreachable)\n202\t    process.env.PATH = '/nonexistent-gsd-t-test-path';\n203\t\n204\t    const r = runCiParity({ projectDir: tmp, timeoutMs: 10000 });\n205\t\n206\t    // Contract assertions\n207\t    assert.equal(r.ok, true, 'docker-unavailable must NOT be a hard failure (ok must be true)');\n208\t    assert.equal(r.dockerBuilt, false, 'dockerBuilt must be false when docker binary is absent');\n209\t    assert.equal(r.dockerSkippedReason, 'docker-unavailable', 'dockerSkippedReason must be \"docker-unavailable\"');\n210\t  } finally {\n211\t    process.env.PATH = origPath;\n212\t    fs.rmSync(tmp, { recursive: true, force: true });\n213\t  }\n214\t});\n215\t\n216\t// ── runCiParity integration: fast no-op fixtures ───────────────────────────────\n217\t\n218\ttest('run_ci_parity_cloudbuild_commands_pass', () => {\n219\t  const r = runCiParity({ projectDir: fixtureDir('cloudbuild'), timeoutMs: 15000 });\n220\t  assert.equal(r.detectedSource, 'cloudbuild');\n221\t  assert.ok(r.commands.length > 0, 'Should have run commands');\n222\t  // All commands in this fixture are node no-ops → should pass\n223\t  const allOk = r.commands.every((c) => c.ok);\n224\t  assert.ok(allOk, `All cloudbuild commands should pass; got: ${JSON.stringify(r.commands)}`);\n225\t});\n226\t\n227\ttest('run_ci_parity_workflows_commands_pass', () => {\n228\t  const r = runCiParity({ projectDir: fixtureDir('workflows'), timeoutMs: 15000 });\n229\t  assert.equal(r.detectedSource, 'workflows');\n230\t  assert.ok(r.commands.length > 0, 'Should have run commands');\n231\t});\n232\t\n233\ttest('run_ci_parity_pkg_fallback_commands_pass', () => {\n234\t  const r = runCiParity({ projectDir: fixtureDir('pkg-fallback'), timeoutMs: 15000 });\n235\t  assert.equal(r.detectedSource, 'package-scripts');\n236\t  assert.ok(r.commands.length > 0);\n237\t  assert.ok(r.commands.every((c) => c.ok), `All pkg-fallback commands should pass; got: ${JSON.stringify(r.commands)}`);\n238\t});\n239\t\n240\ttest('run_ci_parity_none_returns_ok_true', () => {\n241\t  const tmp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'gsd-t-ci-parity-empty-'));\n242\t  try {\n243\t    // Empty dir → none source → ok:true\n244\t    const r = runCiParity({ projectDir: tmp, timeoutMs: 5000 });\n245\t    assert.equal(r.detectedSource, 'none');\n246\t    assert.ok(r.ok, 'none-detected should be ok:true');\n247\t    assert.ok(r.note, 'Should include a note for none-detected');\n248\t  } finally {\n249\t    fs.rmSync(tmp, { recursive: true, force: true });\n250\t  }\n251\t});\n252\t\n253\t// ── Envelope shape ────────────────────────────────────────────────────────────\n254\t\n255\ttest('envelope_shape_has_required_fields', () => {\n256\t  const r = runCiParity({ projectDir: fixtureDir('pkg-fallback'), timeoutMs: 10000 });\n257\t  assert.ok('ok' in r, 'envelope must have ok');\n258\t  assert.ok('detectedSource' in r, 'envelope must have detectedSource');\n259\t  assert.ok('commands' in r, 'envelope must have commands');\n260\t  assert.ok('dockerBuilt' in r, 'envelope must have dockerBuilt');\n261\t  assert.ok(Array.isArray(r.commands), 'commands must be array');\n262\t  for (const c of r.commands) {\n263\t    assert.ok('cmd' in c, 'command entry must have cmd');\n264\t    assert.ok('exitCode' in c, 'command entry must have exitCode');\n265\t    assert.ok('ok' in c, 'command entry must have ok');\n266\t  }\n267\t});\n268\t\n269\t// ── SC2: Planted regression test (docker-dependent, self-skips) ───────────────\n270\t\n271\ttest('SC2_planted_regression_docker_build_fails', { skip: !isDockerAvailable() ? 'No Docker daemon available — SC2 docker-dependent assertion skipped. Detection+cache-clear path tested unconditionally below.' : false }, async () => {\n272\t  const d = fixtureDir('planted-regression');\n273\t\n274\t  // First: unconditional assertions (detection + cache clear)\n275\t  const detected = detectCi(d);\n276\t  // planted-regression has Dockerfile → dockerfile-run source\n277\t  assert.equal(detected.source, 'dockerfile-run', 'SC2 fixture must detect dockerfile-run source');\n278\t\n279\t  // Plant the stale .tsbuildinfo back (in case a previous run removed it)\n280\t  const tsBuildInfoPath = path.join(d, '.tsbuildinfo');\n281\t  const staleContent = JSON.stringify({\n282\t    program: { fileNames: ['./src/index.ts'], fileInfos: [{ version: 'stale', signature: 'stale' }], options: {} },\n283\t    version: '4.9.5',\n284\t  });\n285\t  fs.writeFileSync(tsBuildInfoPath, staleContent);\n286\t  assert.ok(fs.existsSync(tsBuildInfoPath), 'Stale .tsbuildinfo must be present before test');\n287\t\n288\t  // When docker IS available: run the full parity check\n289\t  // This should remove the stale .tsbuildinfo AND run docker build which FAILS\n290\t  // because the Dockerfile runs npx tsc --noEmit and the src/index.ts has\n291\t  // a noImplicitAny violation.\n292\t  const r = runCiParity({ projectDir: d, timeoutMs: 180000 }); // 3 min for docker build\n293\t\n294\t  // Docker must have attempted to build\n295\t  assert.ok(\n296\t    r.dockerBuilt === false || r.dockerSkippedReason === undefined,\n297\t    'dockerBuilt should be false (failed) when docker runs'\n298\t  );\n299\t\n300\t  // ok must be false — regression was caught\n301\t  assert.equal(r.ok, false, 'SC2: docker build must fail → ok:false');\n302\t\n303\t  // Stale .tsbuildinfo must have been cleared before commands ran\n304\t  // (cache clear runs before commands, so even if docker build failed the file is gone)\n305\t  // Note: the .tsbuildinfo we planted must have been cleared\n306\t  // (runCiParity clears before running commands)\n307\t});\n308\t\n309\ttest('SC2_detection_and_cache_clear_unconditional', () => {\n310\t  // This portion of SC2 always runs regardless of Docker availability.\n311\t  const d = fixtureDir('planted-regression');\n312\t\n313\t  // Detection\n314\t  const r = detectCi(d);\n315\t  assert.equal(r.source, 'dockerfile-run', 'SC2 fixture must detect dockerfile-run');\n316\t  assert.ok(r.commands.length > 0, 'SC2 fixture must have commands');\n317\t\n318\t  // Plant stale .tsbuildinfo\n319\t  const staleFile = path.join(d, '.tsbuildinfo');\n320\t  fs.writeFileSync(staleFile, '{\"version\":\"stale-for-test\"}');\n321\t  assert.ok(fs.existsSync(staleFile), 'Stale file must exist before cache clear');\n322\t\n323\t  // Cache clear removes it\n324\t  clearBuildCaches(d);\n325\t  assert.ok(!fs.existsSync(staleFile), 'Cache clear must remove the stale .tsbuildinfo (SC2 anti-regression)');\n326\t});\n327\t\n328\t// ── CLI exit code tests ────────────────────────────────────────────────────────\n329\t\n330\ttest('cli_exit_0_on_ok_true', () => {\n331\t  const r = child_process.spawnSync(\n332\t    process.execPath,\n333\t    [path.join(__dirname, '..', 'bin', 'gsd-t-ci-parity.cjs'), '--json',\n334\t     '--project-dir', fixtureDir('pkg-fallback'), '--timeout-ms', '15000'],\n335\t    { encoding: 'utf8' }\n336\t  );\n337\t  assert.equal(r.status, 0, `Expected exit 0, got ${r.status}. stdout: ${r.stdout}`);\n338\t  const out = JSON.parse(r.stdout.trim());\n339\t  assert.equal(out.ok, true);\n340\t});\n341\t\n342\ttest('cli_json_output_has_correct_shape', () => {\n343\t  // Uses pkg-fallback fixture: no cloudbuild, no workflows, no Dockerfile → package-scripts source.\n344\t  const r = child_process.spawnSync(\n345\t    process.execPath,\n346\t    [path.join(__dirname, '..', 'bin', 'gsd-t-ci-parity.cjs'), '--json',\n347\t     '--project-dir', fixtureDir('pkg-fallback'), '--timeout-ms', '15000'],\n348\t    { encoding: 'utf8' }\n349\t  );\n350\t  const out = JSON.parse(r.stdout.trim());\n351\t  // Value-type and value assertions — must fail on {ok:null, detectedSource:'', commands:null, dockerBuilt:null}\n352\t  assert.equal(typeof out.ok, 'boolean', 'ok must be a boolean');\n353\t  assert.equal(out.detectedSource, 'package-scripts', 'detectedSource must be \"package-scripts\" for pkg-fallback fixture');\n354\t  assert.ok(Array.isArray(out.commands), 'commands must be an array');\n355\t  assert.equal(typeof out.dockerBuilt, 'boolean', 'dockerBuilt must be a boolean');\n356\t});\n357\t\n358\ttest('cli_exit_4_on_ok_false', () => {\n359\t  // Create a fixture that will fail: a command with non-zero exit\n360\t  const tmp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'gsd-t-ci-parity-fail-'));\n361\t  try {\n362\t    fs.writeFileSync(path.join(tmp, 'package.json'), JSON.stringify({\n363\t      name: 'test-fail',\n364\t      scripts: { build: 'node -e \"process.exit(1)\"' },\n365\t    }));\n366\t    const r = child_process.spawnSync(\n367\t      process.execPath,\n368\t      [path.join(__dirname, '..', 'bin', 'gsd-t-ci-parity.cjs'), '--json',\n369\t       '--project-dir', tmp, '--timeout-ms', '10000'],\n370\t      { encoding: 'utf8' }\n371\t    );\n372\t    assert.equal(r.status, 4, `Expected exit 4, got ${r.status}. stdout: ${r.stdout}`);\n373\t    const out = JSON.parse(r.stdout.trim());\n374\t    assert.equal(out.ok, false);\n375\t  } finally {\n376\t    fs.rmSync(tmp, { recursive: true, force: true });\n377\t  }\n378\t});\n379\t\n380\ttest('cli_help_exits_0', () => {\n381\t  const r = child_process.spawnSync(\n382\t    process.execPath,\n383\t    [path.join(__dirname, '..', 'bin', 'gsd-t-ci-parity.cjs'), '--help'],\n384\t    { encoding: 'utf8' }\n385\t  );\n386\t  assert.equal(r.status, 0, `--help should exit 0, got ${r.status}`);\n387\t});\n388\t"}]},"parent_tool_use_id":"toolu_01XvmJcXCY9Z93dXSSMyPSUp","session_id":"58ad06dd-2644-4e21-9536-13779b8ab76f","uuid":"834f8786-c29a-4b97-9cb3-e3d89618207c","timestamp":"2026-05-18T21:58:48.139Z","subagent_type":"general-purpose","task_description":"QA re-verify M57 fixes"}
