{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CQqncnPXWoMZQiUrQnWi8p","type":"tool_result","content":"184\ttest('docker_unavailable_is_not_hard_failure', () => {\n185\t  // Use a temp dir with a Dockerfile but simulate docker-unavailable by\n186\t  // checking the path; we test the module logic via the return envelope shape.\n187\t  // This test validates the contract: docker-unavailable → non-failure.\n188\t  const tmp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'gsd-t-ci-parity-docker-'));\n189\t  try {\n190\t    fs.writeFileSync(path.join(tmp, 'Dockerfile'), 'FROM scratch\\n');\n191\t    fs.writeFileSync(path.join(tmp, 'package.json'), JSON.stringify({\n192\t      name: 'test', scripts: { build: 'node -e \"process.exit(0)\"' },\n193\t    }));\n194\t    // We can't easily simulate docker binary missing in a unit test without\n195\t    // PATH manipulation, so we test the no-dockerfile case and verify\n196\t    // the envelope shape is correct for the unavailable path via module internals.\n197\t    // The SC2 test covers docker-present behavior.\n198\t    // Assertion: when docker IS available, dockerSkippedReason is absent;\n199\t    // when absent (no Dockerfile), it is 'no-dockerfile'. The 'docker-unavailable'\n200\t    // path is exercised by the SC2 self-skip guard.\n201\t    const noDockerDir = fixtureDir('pkg-fallback');\n202\t    const r2 = runCiParity({ projectDir: noDockerDir, timeoutMs: 10000 });\n203\t    assert.equal(r2.dockerSkippedReason, 'no-dockerfile');\n204\t    assert.ok(typeof r2.ok === 'boolean', 'ok must be boolean');\n205\t  } finally {\n206\t    fs.rmSync(tmp, { recursive: true, force: true });\n207\t  }\n208\t});"}]},"parent_tool_use_id":"toolu_01J245C9fJtqpodsN3b7Uj7M","session_id":"58ad06dd-2644-4e21-9536-13779b8ab76f","uuid":"c0a265a0-ce2f-4f91-ab7f-e4876644797d","timestamp":"2026-05-18T21:53:43.791Z","subagent_type":"general-purpose","task_description":"QA validation M57"}
