{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UqTs5dXML5LQKnrKb2DoMK","type":"tool_result","content":"210\t */\n211\tfunction checkBuildCoverage({ projectDir, baseRef, headRef, _newPaths }) {\n212\t  // Resolve refs (throws UsageError for bad state — caller handles)\n213\t  const { base, head } = resolveRefs(projectDir, baseRef, headRef);\n214\t\n215\t  // Enumerate new top-level paths\n216\t  let newPaths;\n217\t  if (_newPaths !== undefined) {\n218\t    // Test seam: caller supplies the diff list directly\n219\t    newPaths = collapseToTopLevel(_newPaths);\n220\t  } else {\n221\t    const changedFiles = gitDiffNames(projectDir, base, head);\n222\t    newPaths = collapseToTopLevel(changedFiles);\n223\t  }\n224\t\n225\t  // Empty diff — nothing to check\n226\t  if (newPaths.length === 0) {\n227\t    return { ok: true, missing: [], checkedAgainst: [], newPaths: [], note: 'empty diff' };\n228\t  }\n229\t\n230\t  // Detect CI artifacts\n231\t  const { artifacts, coversAll, coveredPaths } = detectCIArtifacts(projectDir);\n232\t\n233\t  // No CI artifacts — not a failure (nothing to be inconsistent with)\n234\t  if (artifacts.length === 0) {\n235\t    return {\n236\t      ok: true,\n237\t      missing: [],\n238\t      checkedAgainst: [],\n239\t      newPaths,\n240\t      note: 'no CI artifacts detected',\n241\t    };\n242\t  }\n243\t\n244\t  // COPY . . covers everything\n245\t  if (coversAll) {\n246\t    return { ok: true, missing: [], checkedAgainst: artifacts, newPaths };\n247\t  }\n248\t\n249\t  // Check which new paths are not referenced\n250\t  const coveredSet = new Set(coveredPaths);\n251\t  const missing = newPaths.filter(p => !coveredSet.has(p));\n252\t\n253\t  return {\n254\t    ok: missing.length === 0,\n255\t    missing,\n256\t    checkedAgainst: artifacts,\n257\t    newPaths,\n258\t  };\n259\t}"}]},"parent_tool_use_id":"toolu_01J245C9fJtqpodsN3b7Uj7M","session_id":"58ad06dd-2644-4e21-9536-13779b8ab76f","uuid":"0ace7582-e4ba-4162