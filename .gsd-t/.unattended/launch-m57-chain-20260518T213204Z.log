{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019JiGU19De6K3icNCxzLGUx","type":"tool_result","content":"1\t'use strict';\n2\t/**\n3\t * M57 D1 — Build Coverage Check tests\n4\t *\n5\t * Tests `bin/gsd-t-build-coverage.cjs` including SC1: the TimeTracking\n6\t * v1.10.12 failure class (new `hooks/` dir committed but absent from\n7\t * Dockerfile COPY → ok:false, missing:[\"hooks\"], CLI exit 4).\n8\t *\n9\t * Uses Node built-in test runner (`node --test`). Zero new deps.\n10\t * All tests use the `_newPaths` seam to bypass live git calls, making them\n11\t * deterministic without needing a git repo with a specific commit range.\n12\t *\n13\t * Contract: .gsd-t/contracts/cli-build-coverage-contract.md v1.0.0 STABLE.\n14\t */\n15\t\n16\tconst test   = require('node:test');\n17\tconst assert = require('node:assert');\n18\tconst path   = require('node:path');\n19\tconst { spawnSync } = require('node:child_process');\n20\t\n21\tconst { checkBuildCoverage } = require('../bin/gsd-t-build-coverage.cjs');\n22\t\n23\t// Absolute path to test fixtures\n24\tconst FIXTURES = path.join(__dirname, 'fixtures', 'm57-build-coverage');\n25\t\n26\t// ---------------------------------------------------------------------------\n27\t// Helpers\n28\t// ---------------------------------------------------------------------------\n29\t\n30\t/** Run the CLI as a subprocess with given argv; returns { status, stdout, stderr } */\n31\tfunction runCLI(argv) {\n32\t  const result = spawnSync(\n33\t    process.execPath,\n34\t    [path.join(__dirname, '..', 'bin', 'gsd-t-build-coverage.cjs'), ...argv],\n35\t    { encoding: 'utf8', stdio: ['ignore', 'pipe', 'pipe'] }\n36\t  );\n37\t  return { status: result.status, stdout: result.stdout, stderr: result.stderr };\n38\t}\n39\t\n40\t// ---------------------------------------------------------------------------\n41\t// SC1 — TimeTracking failure class (docker-cloudbuild fixture)\n42\t// ---------------------------------------------------------------------------\n43\t\n44\ttest('SC1: new hooks/ dir not COPY\\'d → ok:false, missing includes \"hooks\", API', () => {\n45\t  const projectDir = path.join(FIXTURES, 'docker-cloudbuild');\n46\t  const result = checkBuildCoverage({\n47\t    projectDir,\n48\t    _newPaths: ['hooks/post-deploy.sh', 'src/index.js'],\n49\t  });\n50\t  assert.strictEqual(result.ok, false, 'ok should be false');\n51\t  assert.ok(result.missing.includes('hooks'), `missing should include \"hooks\", got: ${JSON.stringify(result.missing)}`);\n52\t  assert.ok(Array.isArray(result.newPaths), 'newPaths should be an array');\n53\t  assert.ok(result.newPaths.includes('hooks'), 'newPaths should include hooks');\n54\t  assert.ok(result.newPaths.includes('src'), 'newPaths should include src');\n55\t  assert.ok(Array.isArray(result.checkedAgainst), 'checkedAgainst should be array');\n56\t  assert.ok(result.checkedAgainst.includes('Dockerfile'), 'checkedAgainst should include Dockerfile');\n57\t});\n58\t\n59\ttest('SC1: CLI subprocess exits 4 for docker-cloudbuild fixture with hooks/ uncovered', () => {\n60\t  // We can't inject _newPaths via CLI, so we need a test approach:\n61\t  // Run against a temp dir that has the fixture Dockerfile but we override\n62\t  // the diff by using a real git diff. Instead, we test the exit-4 path\n63\t  // by pointing the CLI at a real project where HEAD~1..HEAD would produce\n64\t  // the right diff — but that's environment-dependent.\n65\t  //\n66\t  // Better: test the API path (above) proves ok:false + missing:[\"hooks\"].\n67\t  // For the CLI exit-4 test, we use the --base/--head pointing to a range\n68\t  // that produces a known diff. Since we can't guarantee git history here,\n69\t  // we instead verify exit 4 via a small synthetic git repo in a temp dir.\n70\t  const os = require('os');\n71\t  const fs = require('fs');\n72\t\n73\t  const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'm57-sc1-'));\n74\t\n75\t  // Copy Dockerfile fixture\n76\t  fs.mkdirSync(path.join(tmpDir, 'src'), { recursive: true });\n77\t  fs.mkdirSync(path.join(tmpDir, 'hooks'), { recursive: true });\n78\t  fs.writeFileSync(\n79\t    path.join(tmpDir, 'Dockerfile'),\n80\t    fs.readFileSync(path.join(FIXTURES, 'docker-cloudbuild', 'Dockerfile'), 'utf8')\n81\t  );\n82\t  fs.writeFileSync(path.join(tmpDir, 'src', 'index.js'), '// src');\n83\t  fs.writeFileSync(path.join(tmpDir, 'hooks', 'post-deploy.sh'), '#!/bin/sh');\n84\t\n85\t  // Init git repo with two commits: base (src only), head (add hooks)\n86\t  const gitOpts = { cwd: tmpDir, encoding: 'utf8', stdio: ['ignore', 'pipe', 'pipe'] };\n87\t  spawnSync('git', ['init', '-b', 'main'], gitOpts);\n88\t  spawnSync('git', ['config', 'user.email', 'test@test.com'], gitOpts);\n89\t  spawnSync('git', ['config', 'user.name', 'Test'], gitOpts);\n90\t  // First commit: Dockerfile + src\n91\t  spawnSync('git', ['add', 'Dockerfile', 'src/'], gitOpts);\n92\t  spawnSync('git', ['commit', '-m', 'base'], gitOpts);\n93\t  // Second commit: add hooks/\n94\t  spawnSync('git', ['add', 'hooks/'], gitOpts);\n95\t  spawnSync('git', ['commit', '-m', 'add hooks'], gitOpts);\n96\t\n97\t  const { status, stdout, stderr } = runCLI([\n98\t    '--json',\n99\t    '--project-dir', tmpDir,\n100\t    '--base', 'HEAD~1',\n101\t    '--head', 'HEAD',\n102\t  ]);\n103\t\n104\t  // Cleanup\n105\t  fs.rmSync(tmpDir, { recursive: true, force: true });\n106\t\n107\t  assert.strictEqual(status, 4, `expected exit 4, got ${status}. stdout=${stdout} stderr=${stderr}`);\n108\t  const envelope = JSON.parse(stdout);\n109\t  assert.strictEqual(envelope.ok, false);\n110\t  assert.ok(envelope.missing.includes('hooks'), `expected missing to include \"hooks\": ${JSON.stringify(envelope.missing)}`);\n111\t});\n112\t\n113\t// ---------------------------------------------------------------------------\n114\t// copy-dot fixture — COPY . . covers everything\n115\t// ---------------------------------------------------------------------------\n116\t\n117\ttest('copy-dot: Dockerfile with COPY . . → ok:true', () => {\n118\t  const projectDir = path.join(FIXTURES, 'copy-dot');\n119\t  const result = checkBuildCoverage({\n120\t    projectDir,\n121\t    _newPaths: ['hooks/post-deploy.sh', 'workers/task.js', 'src/new-module.js'],\n122\t  });\n123\t  assert.strictEqual(result.ok, true, `expected ok:true, got ok:false missing=${JSON.stringify(result.missing)}`);\n124\t  assert.deepStrictEqual(result.missing, []);\n125\t  assert.ok(result.checkedAgainst.includes('Dockerfile'));\n126\t});\n127\t\n128\t// ---------------------------------------------------------------------------\n129\t// no-ci fixture — no CI artifacts → ok:true with note\n130\t// ---------------------------------------------------------------------------\n131\t\n132\ttest('no-ci: no Dockerfile/cloudbuild/workflows → ok:true with note', () => {\n133\t  const projectDir = path.join(FIXTURES, 'no-ci');\n134\t  const result = checkBuildCoverage({\n135\t    projectDir,\n136\t    _newPaths: ['hooks/post-deploy.sh'],\n137\t  });\n138\t  assert.strictEqual(result.ok, true, 'expected ok:true when no CI artifacts');\n139\t  assert.ok(typeof result.note === 'string' && result.note.length > 0, 'expected note to be set');\n140\t  assert.ok(result.note.includes('no CI artifacts'), `note should mention no CI artifacts, got: ${result.note}`);\n141\t  assert.deepStrictEqual(result.checkedAgainst, []);\n142\t});\n143\t\n144\ttest('no-ci fixture: CLI exits 0', () => {\n145\t  // Use this project's own dir as a \"no-CI\" stand-in by pointing at no-ci fixture.\n146\t  // We can't run git diff, so test the API route proves exit 0 via code path.\n147\t  // Direct CLI test: run against no-ci fixture with a synthetic git repo.\n148\t  const os = require('os');\n149\t  const fs = require('fs');\n150\t  const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'm57-noci-'));\n151\t  fs.mkdirSync(path.join(tmpDir, 'src'), { recursive: true });\n152\t  fs.writeFileSync(path.join(tmpDir, 'src', 'index.js'), '// src');\n153\t\n154\t  const gitOpts = { cwd: tmpDir, encoding: 'utf8', stdio: ['ignore', 'pipe', 'pipe'] };\n155\t  spawnSync('git', ['init', '-b', 'main'], gitOpts);\n156\t  spawnSync('git', ['config', 'user.email', 'test@test.com'], gitOpts);\n157\t  spawnSync('git', ['config', 'user.name', 'Test'], gitOpts);\n158\t  spawnSync('git', ['add', '.'], gitOpts);\n159\t  spawnSync('git', ['commit', '-m', 'base'], gitOpts);\n160\t  fs.mkdirSync(path.join(tmpDir, 'hooks'), { recursive: true });\n161\t  fs.writeFileSync(path.join(tmpDir, 'hooks', 'run.sh'), '#!/bin/sh');\n162\t  spawnSync('git', ['add', 'hooks/'], gitOpts);\n163\t  spawnSync('git', ['commit', '-m', 'add hooks'], gitOpts);\n164\t\n165\t  const { status, stdout } = runCLI(['--json', '--project-dir', tmpDir, '--base', 'HEAD~1', '--head', 'HEAD']);\n166\t  fs.rmSync(tmpDir, { recursive: true, force: true });\n167\t\n168\t  assert.strictEqual(status, 0, `expected exit 0 for no-ci, got ${status}`);\n169\t  const envelope = JSON.parse(stdout);\n170\t  assert.strictEqual(envelope.ok, true);\n171\t  assert.ok(typeof envelope.note === 'string');\n172\t});\n173\t\n174\t// ---------------------------------------------------------------------------\n175\t// empty-diff path\n176\t// ---------------------------------------------------------------------------\n177\t\n178\ttest('empty diff → ok:true, newPaths:[]', () => {\n179\t  const projectDir = path.join(FIXTURES, 'docker-cloudbuild');\n180\t  const result = checkBuildCoverage({\n181\t    projectDir,\n182\t    _newPaths: [],\n183\t  });\n184\t  assert.strictEqual(result.ok, true);\n185\t  assert.deepStrictEqual(result.newPaths, []);\n186\t  assert.deepStrictEqual(result.missing, []);\n187\t});\n188\t\n189\t// ---------------------------------------------------------------------------\n190\t// usage error / bad ref → exit 2\n191\t// ---------------------------------------------------------------------------\n192\t\n193\ttest('usage error (bad git ref) → exit 2', () => {\n194\t  const os = require('os');\n195\t  const fs = require('fs');\n196\t  const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'm57-bad-'));\n197\t  // Init a real git repo with one commit so the repo check passes\n198\t  const gitOpts = { cwd: tmpDir, encoding: 'utf8', stdio: ['ignore', 'pipe', 'pipe'] };\n199\t  fs.writeFileSync(path.join(tmpDir, 'README.md'), '# test');\n200\t  spawnSync('git', ['init', '-b', 'main'], gitOpts);\n201\t  spawnSync('git', ['config', 'user.email', 'test@test.com'], gitOpts);\n202\t  spawnSync('git', ['config', 'user.name', 'Test'], gitOpts);\n203\t  spawnSync('git', ['add', '.'], gitOpts);\n204\t  spawnSync('git', ['commit', '-m', 'init'], gitOpts);\n205\t\n206\t  const { status } = runCLI([\n207\t    '--project-dir', tmpDir,\n208\t    '--base', 'nonexistent-ref-abc123',\n209\t    '--head', 'HEAD',\n210\t  ]);\n211\t  fs.rmSync(tmpDir, { recursive: true, force: true });\n212\t\n213\t  assert.strictEqual(status, 2, `expected exit 2 for bad ref, got ${status}`);\n214\t});\n215\t\n216\ttest('usage error (not a git repo) → exit 2', () => {\n217\t  const os = require('os');\n218\t  const fs = require('fs');\n219\t  const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'm57-nogit-'));\n220\t  // No git init — not a repo\n221\t\n222\t  const { status } = runCLI(['--project-dir', tmpDir]);\n223\t  fs.rmSync(tmpDir, { recursive: true, force: true });\n224\t\n225\t  assert.strictEqual(status, 2, `expected exit 2 for non-git dir, got ${status}`);\n226\t});\n227\t\n228\t// ---------------------------------------------------------------------------\n229\t// gha-only fixture — uncovered path flagged\n230\t// ---------------------------------------------------------------------------\n231\t\n232\ttest('gha-only: workflow references src/ but not hooks/ → hooks in missing', () => {\n233\t  const projectDir = path.join(FIXTURES, 'gha-only');\n234\t  const result = checkBuildCoverage({\n235\t    projectDir,\n236\t    _newPaths: ['hooks/post-deploy.sh', 'src/index.js'],\n237\t  });\n238\t  // The workflow references \"src\" in rsync/cp lines but not \"hooks\"\n239\t  assert.ok(Array.isArray(result.missing), 'missing should be array');\n240\t  assert.ok(result.missing.includes('hooks'), `expected hooks in missing, got ${JSON.stringify(result.missing)}`);\n241\t  assert.strictEqual(result.ok, false, 'ok should be false when hooks not covered');\n242\t  assert.ok(result.checkedAgainst.some(a => a.includes('workflows')), 'checkedAgainst should include workflows');\n243\t});\n244\t\n245\t// ---------------------------------------------------------------------------\n246\t// Additional unit-level tests for parser behavior\n247\t// ---------------------------------------------------------------------------\n248\t\n249\ttest('checkBuildCoverage: src/ present in Dockerfile COPY → src not in missing', () => {\n250\t  const projectDir = path.join(FIXTURES, 'docker-cloudbuild');\n251\t  // Only src in diff — it IS in Dockerfile COPY src/\n252\t  const result = checkBuildCoverage({\n253\t    projectDir,\n254\t    _newPaths: ['src/new-file.js'],\n255\t  });\n256\t  assert.strictEqual(result.ok, true, `expected ok:true for src (covered), got missing=${JSON.stringify(result.missing)}`);\n257\t  assert.deepStrictEqual(result.missing, []);\n258\t});\n259\t\n260\ttest('checkBuildCoverage: multiple uncovered paths all appear in missing[]', () => {\n261\t  const projectDir = path.join(FIXTURES, 'docker-cloudbuild');\n262\t  const result = checkBuildCoverage({\n263\t    projectDir,\n264\t    _newPaths: ['hooks/run.sh', 'workers/task.js', 'src/x.js'],\n265\t  });\n266\t  assert.strictEqual(result.ok, false);\n267\t  assert.ok(result.missing.includes('hooks'), 'hooks should be missing');\n268\t  assert.ok(result.missing.includes('workers'), 'workers should be missing');\n269\t  assert.ok(!result.missing.includes('src'), 'src should NOT be missing (it is COPY\\'d)');\n270\t});\n271\t\n272\ttest('checkBuildCoverage: identical baseRef/headRef → throws UsageError (caught by CLI as exit 2)', () => {\n273\t  // The API throws UsageError for identical refs; CLI catches and exits 2.\n274\t  // Test the UsageError throw directly by calling resolveRefs indirectly via checkBuildCoverage.\n275\t  // We pass a real repo dir (this project) but identical refs — but _newPaths is not provided so\n276\t  // it will call git. Instead, test via a temp repo.\n277\t  const os = require('os');\n278\t  const fs = require('fs');\n279\t  const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'm57-same-'));\n280\t  const gitOpts = { cwd: tmpDir, encoding: 'utf8', stdio: ['ignore', 'pipe', 'pipe'] };\n281\t  fs.writeFileSync(path.join(tmpDir, 'README.md'), '# x');\n282\t  spawnSync('git', ['init', '-b', 'main'], gitOpts);\n283\t  spawnSync('git', ['config', 'user.email', 'test@test.com'], gitOpts);\n284\t  spawnSync('git', ['config', 'user.name', 'Test'], gitOpts);\n285\t  spawnSync('git', ['add', '.'], gitOpts);\n286\t  spawnSync('git', ['commit', '-m', 'init'], gitOpts);\n287\t\n288\t  // CLI should exit 2\n289\t  const { status } = runCLI(['--project-dir', tmpDir, '--base', 'HEAD', '--head', 'HEAD']);\n290\t  fs.rmSync(tmpDir, { recursive: true, force: true });\n291\t\n292\t  assert.strictEqual(status, 2, `expected exit 2 for identical refs, got ${status}`);\n293\t});\n294\t\n295\ttest('checkBuildCoverage return shape has all required fields', () => {\n296\t  // Use empty-diff to verify the field set exists\n297\t  const projectDir = path.join(FIXTURES, 'docker-cloudbuild');\n298\t  const emptyResult = checkBuildCoverage({ projectDir, _newPaths: [] });\n299\t  assert.ok('ok' in emptyResult, 'missing ok field');\n300\t  assert.ok('missing' in emptyResult, 'missing missing field');\n301\t  assert.ok('checkedAgainst' in emptyResult, 'missing checkedAgainst field');\n302\t  assert.ok('newPaths' in emptyResult, 'missing newPaths field');\n303\t  assert.ok(typeof emptyResult.ok === 'boolean', 'ok should be boolean');\n304\t  assert.ok(Array.isArray(emptyResult.missing), 'missing should be array');\n305\t  assert.ok(Array.isArray(emptyResult.checkedAgainst), 'checkedAgainst should be array');\n306\t  assert.ok(Array.isArray(emptyResult.newPaths), 'newPaths should be array');\n307\t});\n308\t\n309\ttest('checkBuildCoverage return shape: checkedAgainst non-empty when CI artifacts detected', () => {\n310\t  // Use docker-cloudbuild fixture with a non-empty diff so the full detection\n311\t  // path runs — checkedAgainst must contain the detected Dockerfile artifact.\n312\t  // A stub that only handles the empty-diff early-return path would produce\n313\t  // checkedAgainst:[] and fail this test.\n314\t  const projectDir = path.join(FIXTURES, 'docker-cloudbuild');\n315\t  const result = checkBuildCoverage({\n316\t    projectDir,\n317\t    _newPaths: ['hooks/post-deploy.sh'],\n318\t  });\n319\t  assert.ok('ok' in result, 'missing ok field');\n320\t  assert.ok('missing' in result, 'missing missing field');\n321\t  assert.ok('checkedAgainst' in result, 'missing checkedAgainst field');\n322\t  assert.ok('newPaths' in result, 'missing newPaths field');\n323\t  assert.ok(typeof result.ok === 'boolean', 'ok should be boolean');\n324\t  assert.ok(Array.isArray(result.missing), 'missing should be array');\n325\t  assert.ok(Array.isArray(result.checkedAgainst), 'checkedAgainst should be array');\n326\t  assert.ok(Array.isArray(result.newPaths), 'newPaths should be array');\n327\t  // Critical: checkedAgainst must be non-empty — CI artifact was detected\n328\t  assert.ok(result.checkedAgainst.length > 0, `checkedAgainst must be non-empty when Dockerfile exists, got: ${JSON.stringify(result.checkedAgainst)}`);\n329\t  assert.ok(result.checkedAgainst.includes('Dockerfile'), `checkedAgainst must include \"Dockerfile\", got: ${JSON.stringify(result.checkedAgainst)}`);\n330\t});\n331\t\n332\t// ---------------------------------------------------------------------------\n333\t// COPY --from= exclusion — multi-stage image layers must NOT count as coverage\n334\t// ---------------------------------------------------------------------------\n335\t\n336\ttest('COPY --from= exclusion: dist covered by --from= layer does NOT prevent missing[]', () => {\n337\t  // The docker-cloudbuild fixture Dockerfile contains:\n338\t  //   COPY --from=builder /app/dist ./dist\n339\t  // This is a multi-stage copy from an image layer, not from the workspace.\n340\t  // Per contract, COPY --from= lines are excluded from coverage parsing.\n341\t  // Therefore dist must appear in missing[] when it is a new top-level path.\n342\t  // hooks/ is also injected to ensure ok:false is triggered by at least one path.\n343\t  const projectDir = path.join(FIXTURES, 'docker-cloudbuild');\n344\t  const result = checkBuildCoverage({\n345\t    projectDir,\n346\t    _newPaths: ['dist/bundle.js', 'hooks/x.js'],\n347\t  });\n348\t  // hooks is genuinely uncovered — ok must be false\n349\t  assert.strictEqual(result.ok, false, 'ok should be false (hooks not covered)');\n350\t  // dist appears only via COPY --from= which is excluded — must be in missing\n351\t  assert.ok(result.missing.includes('dist'), `dist should be in missing[] because COPY --from= is excluded; got missing=${JSON.stringify(result.missing)}`);\n352\t  // hooks must also be missing\n353\t  assert.ok(result.missing.includes('hooks'), `hooks should be in missing[]; got missing=${JSON.stringify(result.missing)}`);\n354\t  // src is not in diff — should not appear in newPaths or missing\n355\t  assert.ok(!result.missing.includes('src'), 'src should not be in missing (not in diff)');\n356\t});\n357\t"}]},"parent_tool_use_id":"toolu_01XvmJcXCY9Z93dXSSMyPSUp","session_id":"58ad06dd-2644-4e21-9536-13779b8ab76f","uuid":"fef721c5-4bd9-4d19-aa49-3c3aa063f1a7","timestamp":"2026-05-18T21:58:47.824Z","subagent_type":"general-purpose","task_description":"QA re-verify M57 fixes"}
