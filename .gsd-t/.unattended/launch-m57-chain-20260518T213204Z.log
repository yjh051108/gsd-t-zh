{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WWZjukiAK9NYHmnvGdESYc","type":"tool_result","content":"1\t#!/usr/bin/env node\n2\t'use strict';\n3\t\n4\t/**\n5\t * GSD-T build-coverage (M57 D1)\n6\t *\n7\t * Detects new top-level paths added in a milestone commit range that no\n8\t * CI build artifact references — the TimeTracking v1.10.12 failure class\n9\t * (new `hooks/` dir committed, absent from Dockerfile COPY, shipped broken\n10\t * while local verify reported VERIFIED).\n11\t *\n12\t * Exports: checkBuildCoverage({ projectDir, baseRef, headRef })\n13\t * CLI:     node bin/gsd-t-build-coverage.cjs [--json] [--base REF] [--head REF]\n14\t *\n15\t * Contract: .gsd-t/contracts/cli-build-coverage-contract.md v1.0.0 STABLE.\n16\t *\n17\t * Exit codes (CLI):\n18\t *   0 — ok:true (all new paths covered, OR no CI artifacts found)\n19\t *   4 — ok:false (≥1 new top-level path uncovered)\n20\t *   2 — usage error (bad refs, not a git repo, detached HEAD)\n21\t *\n22\t * Hard rules:\n23\t *   1. Zero external runtime deps — Node built-ins only.\n24\t *   2. Functions <30 lines where practical.\n25\t *   3. Defensive: never throw out of checkBuildCoverage; usage errors surface\n26\t *      as a thrown UsageError caught by the CLI entry.\n27\t */\n28\t\n29\tconst fs   = require('fs');\n30\tconst path = require('path');\n31\tconst { execSync } = require('child_process');\n32\t\n33\t// ---------------------------------------------------------------------------\n34\t// Error type\n35\t// ---------------------------------------------------------------------------\n36\t\n37\tclass UsageError extends Error {\n38\t  constructor(message) {\n39\t    super(message);\n40\t    this.name = 'UsageError';\n41\t  }\n42\t}\n43\t\n44\t// ---------------------------------------------------------------------------\n45\t// Git helpers\n46\t// ---------------------------------------------------------------------------\n47\t\n48\t/** Run git diff --name-only baseRef..headRef, return array of changed file paths. */\n49\tfunction gitDiffNames(projectDir, baseRef, headRef) {\n50\t  const range = `${baseRef}..${headRef}`;\n51\t  const raw = execSync(`git diff --name-only ${range}`, {\n52\t    cwd: projectDir,\n53\t    encoding: 'utf8',\n54\t    stdio: ['ignore', 'pipe', 'pipe'],\n55\t  });\n56\t  return raw.split('\\n').map(s => s.trim()).filter(Boolean);\n57\t}\n58\t\n59\t/** Resolve default refs; throws UsageError if repo state is unusable. */\n60\tfunction resolveRefs(projectDir, baseRef, headRef) {\n61\t  // Verify it's a git repo\n62\t  execSync('git rev-parse --git-dir', {\n63\t    cwd: projectDir,\n64\t    encoding: 'utf8',\n65\t    stdio: ['ignore', 'pipe', 'pipe'],\n66\t  });\n67\t  const base = baseRef || 'HEAD~1';\n68\t  const head = headRef || 'HEAD';\n69\t  if (base === head) {\n70\t    throw new UsageError(`baseRef and headRef are identical: ${base}`);\n71\t  }\n72\t  return { base, head };\n73\t}\n74\t\n75\t/** Collapse a list of file paths to distinct top-level path segments. */\n76\tfunction collapseToTopLevel(filePaths) {\n77\t  const seen = new Set();\n78\t  for (const p of filePaths) {\n79\t    const seg = p.split('/')[0];\n80\t    if (seg) seen.add(seg);\n81\t  }\n82\t  return Array.from(seen).sort();\n83\t}\n84\t\n85\t// ---------------------------------------------------------------------------\n86\t// CI-artifact parsers\n87\t// ---------------------------------------------------------------------------\n88\t\n89\t/** Parse Dockerfile: return { found: boolean, coversAll: boolean, paths: string[] } */\n90\tfunction parseDockerfile(filePath) {\n91\t  const lines = fs.readFileSync(filePath, 'utf8').split('\\n');\n92\t  const paths = [];\n93\t  let coversAll = false;\n94\t  for (const line of lines) {\n95\t    const trimmed = line.trim();\n96\t    // Skip COPY --from= (multi-stage copy from image, not from workspace)\n97\t    if (/^COPY\\s+--from=/i.test(trimmed)) continue;\n98\t    // Match COPY or ADD directives\n99\t    const m = trimmed.match(/^(?:COPY|ADD)\\s+(.+)/i);\n100\t    if (!m) continue;\n101\t    // Parse the source(s) — all tokens except the last (destination)\n102\t    const tokens = m[1].trim().split(/\\s+/);\n103\t    if (tokens.length < 2) continue;\n104\t    const sources = tokens.slice(0, tokens.length - 1);\n105\t    for (const src of sources) {\n106\t      // COPY . . or ADD . . covers everything\n107\t      if (src === '.') { coversAll = true; continue; }\n108\t      // Extract the top-level segment from the source path\n109\t      const seg = src.split('/')[0];\n110\t      if (seg && seg !== '.') paths.push(seg);\n111\t    }\n112\t  }\n113\t  return { found: true, coversAll, paths };\n114\t}\n115\t\n116\t/** Parse cloudbuild.yaml: return array of referenced path segments (line/regex scan). */\n117\tfunction parseCloudBuild(filePath) {\n118\t  const lines = fs.readFileSync(filePath, 'utf8').split('\\n');\n119\t  const paths = [];\n120\t  for (const line of lines) {\n121\t    // Find any word-like path segment that appears in the line (heuristic scan)\n122\t    // Look for patterns like: src/, hooks/, dist/, config/ etc.\n123\t    const matches = line.match(/\\b([a-zA-Z0-9_.-]+)\\//g);\n124\t    if (matches) {\n125\t      for (const m of matches) {\n126\t        const seg = m.replace(/\\/$/, '');\n127\t        if (seg && !seg.startsWith('-') && seg !== '.') paths.push(seg);\n128\t      }\n129\t    }\n130\t  }\n131\t  return paths;\n132\t}\n133\t\n134\t/** Parse .github/workflows/*.yml files: return array of referenced path segments. */\n135\tfunction parseWorkflows(workflowDir) {\n136\t  const paths = [];\n137\t  let files;\n138\t  try {\n139\t    files = fs.readdirSync(workflowDir);\n140\t  } catch {\n141\t    return paths;\n142\t  }\n143\t  for (const f of files) {\n144\t    if (!/\\.ya?ml$/.test(f)) continue;\n145\t    const content = fs.readFileSync(path.join(workflowDir, f), 'utf8');\n146\t    const lines = content.split('\\n');\n147\t    for (const line of lines) {\n148\t      const matches = line.match(/\\b([a-zA-Z0-9_.-]+)\\//g);\n149\t      if (matches) {\n150\t        for (const m of matches) {\n151\t          const seg = m.replace(/\\/$/, '');\n152\t          if (seg && !seg.startsWith('-') && seg !== '.') paths.push(seg);\n153\t        }\n154\t      }\n155\t    }\n156\t  }\n157\t  return paths;\n158\t}\n159\t\n160\t// ---------------------------------------------------------------------------\n161\t// CI artifact detection\n162\t// ---------------------------------------------------------------------------\n163\t\n164\t/** Detect CI artifacts in projectDir; return { artifacts: string[], coversAll: boolean, coveredPaths: string[] } */\n165\tfunction detectCIArtifacts(projectDir) {\n166\t  const artifacts = [];\n167\t  let coversAll = false;\n168\t  const coveredPaths = [];\n169\t\n170\t  const dockerfilePath = path.join(projectDir, 'Dockerfile');\n171\t  if (fs.existsSync(dockerfilePath)) {\n172\t    artifacts.push('Dockerfile');\n173\t    const result = parseDockerfile(dockerfilePath);\n174\t    if (result.coversAll) coversAll = true;\n175\t    coveredPaths.push(...result.paths);\n176\t  }\n177\t\n178\t  const cloudbuildPath = path.join(projectDir, 'cloudbuild.yaml');\n179\t  if (fs.existsSync(cloudbuildPath)) {\n180\t    artifacts.push('cloudbuild.yaml');\n181\t    coveredPaths.push(...parseCloudBuild(cloudbuildPath));\n182\t  }\n183\t\n184\t  const workflowDir = path.join(projectDir, '.github', 'workflows');\n185\t  if (fs.existsSync(workflowDir)) {\n186\t    const wfPaths = parseWorkflows(workflowDir);\n187\t    if (wfPaths.length > 0) {\n188\t      artifacts.push('.github/workflows');\n189\t      coveredPaths.push(...wfPaths);\n190\t    }\n191\t  }\n192\t\n193\t  return { artifacts, coversAll, coveredPaths };\n194\t}\n195\t\n196\t// ---------------------------------------------------------------------------\n197\t// Main API\n198\t// ---------------------------------------------------------------------------\n199\t\n200\t/**\n201\t * Check whether every new top-level path in the milestone commit range is\n202\t * referenced by at least one CI build artifact.\n203\t *\n204\t * @param {object} opts\n205\t * @param {string}  opts.projectDir   - project root (required)\n206\t * @param {string}  [opts.baseRef]    - git base ref (default HEAD~1)\n207\t * @param {string}  [opts.headRef]    - git head ref (default HEAD)\n208\t * @param {string[]} [opts._newPaths] - override diff enumeration (test seam)\n209\t * @returns {{ ok: boolean, missing: string[], checkedAgainst: string[], newPaths: string[], note?: string }}\n210\t */\n211\tfunction checkBuildCoverage({ projectDir, baseRef, headRef, _newPaths }) {\n212\t  // Resolve refs (throws UsageError for bad state — caller handles)\n213\t  const { base, head } = resolveRefs(projectDir, baseRef, headRef);\n214\t\n215\t  // Enumerate new top-level paths\n216\t  let newPaths;\n217\t  if (_newPaths !== undefined) {\n218\t    // Test seam: caller supplies the diff list directly\n219\t    newPaths = collapseToTopLevel(_newPaths);\n220\t  } else {\n221\t    const changedFiles = gitDiffNames(projectDir, base, head);\n222\t    newPaths = collapseToTopLevel(changedFiles);\n223\t  }\n224\t\n225\t  // Empty diff — nothing to check\n226\t  if (newPaths.length === 0) {\n227\t    return { ok: true, missing: [], checkedAgainst: [], newPaths: [], note: 'empty diff' };\n228\t  }\n229\t\n230\t  // Detect CI artifacts\n231\t  const { artifacts, coversAll, coveredPaths } = detectCIArtifacts(projectDir);\n232\t\n233\t  // No CI artifacts — not a failure (nothing to be inconsistent with)\n234\t  if (artifacts.length === 0) {\n235\t    return {\n236\t      ok: true,\n237\t      missing: [],\n238\t      checkedAgainst: [],\n239\t      newPaths,\n240\t      note: 'no CI artifacts detected',\n241\t    };\n242\t  }\n243\t\n244\t  // COPY . . covers everything\n245\t  if (coversAll) {\n246\t    return { ok: true, missing: [], checkedAgainst: artifacts, newPaths };\n247\t  }\n248\t\n249\t  // Check which new paths are not referenced\n250\t  const coveredSet = new Set(coveredPaths);\n251\t  const missing = newPaths.filter(p => !coveredSet.has(p));\n252\t\n253\t  return {\n254\t    ok: missing.length === 0,\n255\t    missing,\n256\t    checkedAgainst: artifacts,\n257\t    newPaths,\n258\t  };\n259\t}\n260\t\n261\t// ---------------------------------------------------------------------------\n262\t// CLI entry\n263\t// ---------------------------------------------------------------------------\n264\t\n265\tfunction parseArgv(argv) {\n266\t  const opts = { json: false, base: undefined, head: undefined, projectDir: process.cwd() };\n267\t  for (let i = 0; i < argv.length; i++) {\n268\t    const a = argv[i];\n269\t    if (a === '--json') opts.json = true;\n270\t    else if (a === '--base') opts.base = argv[++i];\n271\t    else if (a === '--head') opts.head = argv[++i];\n272\t    else if (a === '--project-dir') opts.projectDir = argv[++i];\n273\t    else if (a === '-h' || a === '--help') {\n274\t      process.stdout.write([\n275\t        'Usage: gsd-t build-coverage [--json] [--base REF] [--head REF] [--project-dir PATH]',\n276\t        '',\n277\t        'Exit codes:',\n278\t        '  0  ok:true — all new top-level paths covered, or no CI artifacts found.',\n279\t        '  4  ok:false — ≥1 new top-level path not covered by any CI artifact.',\n280\t        '  2  usage error (bad refs, not a git repo).',\n281\t        '',\n282\t      ].join('\\n'));\n283\t      process.exit(0);\n284\t    }\n285\t  }\n286\t  return opts;\n287\t}\n288\t\n289\tif (require.main === module) {\n290\t  const opts = parseArgv(process.argv.slice(2));\n291\t  let result;\n292\t  try {\n293\t    result = checkBuildCoverage({\n294\t      projectDir: opts.projectDir,\n295\t      baseRef: opts.base,\n296\t      headRef: opts.head,\n297\t    });\n298\t  } catch (e) {\n299\t    if (e && e.name === 'UsageError') {\n300\t      process.stderr.write(`build-coverage: ${e.message}\\n`);\n301\t      process.exit(2);\n302\t    }\n303\t    // Any other error (e.g., git not found, bad ref) — treat as usage error\n304\t    process.stderr.write(`build-coverage: ${e && e.message ? e.message : String(e)}\\n`);\n305\t    process.exit(2);\n306\t  }\n307\t\n308\t  if (opts.json) {\n309\t    process.stdout.write(JSON.stringify(result, null, 2) + '\\n');\n310\t  } else {\n311\t    if (result.ok) {\n312\t      const note = result.note ? ` (${result.note})` : '';\n313\t      process.stdout.write(`OK: all new top-level paths covered${note}\\n`);\n314\t    } else {\n315\t      process.stdout.write(`FAIL: uncovered paths: ${result.missing.join(', ')}\\n`);\n316\t    }\n317\t  }\n318\t\n319\t  process.exit(result.ok ? 0 : 4);\n320\t}\n321\t\n322\tmodule.exports = { checkBuildCoverage };\n323\t"}]},"parent_tool_use_id":"toolu_012gZ3dJs9jRp9CBTGAE7ycq","session_id":"58ad06dd-2644-4e21-9536-13779b8ab76f","uuid":"67c8e418-2c9a-406b-b26e-29630290a08a","timestamp":"2026-05-18T21:55:46.744Z","subagent_type":"general-purpose","task_description":"Fix D1 QA test gaps"}
