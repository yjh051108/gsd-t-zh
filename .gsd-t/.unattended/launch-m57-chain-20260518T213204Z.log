{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q2gc4y3jKwr5MN8iqhGwZN","type":"tool_result","content":"1\t'use strict';\n2\t\n3\t/**\n4\t * Tests for bin/gsd-t-ci-parity.cjs (M57 D2)\n5\t *\n6\t * Covers:\n7\t *  - Detection precedence (cloudbuild → workflows → dockerfile-run → package-scripts → none)\n8\t *  - Cache clearing (stale .tsbuildinfo removed before commands run)\n9\t *  - no-dockerfile / docker-unavailable paths (non-failure)\n10\t *  - SC2: planted noImplicitAny regression caught by real docker build (self-skips when no daemon)\n11\t *\n12\t * Contract: .gsd-t/contracts/ci-parity-contract.md v1.0.0 STABLE\n13\t */\n14\t\n15\tconst { test } = require('node:test');\n16\tconst assert = require('node:assert/strict');\n17\tconst fs = require('fs');\n18\tconst path = require('path');\n19\tconst child_process = require('child_process');\n20\t\n21\tconst { runCiParity, detectCi, clearBuildCaches } = require('../bin/gsd-t-ci-parity.cjs');\n22\t\n23\tconst FIXTURES = path.join(__dirname, 'fixtures', 'm57-ci-parity');\n24\t\n25\t// ── Helpers ────────────────────────────────────────────────────────────────────\n26\t\n27\tfunction fixtureDir(name) {\n28\t  return path.join(FIXTURES, name);\n29\t}\n30\t\n31\tfunction isDockerAvailable() {\n32\t  try {\n33\t    const r = child_process.spawnSync('docker', ['info'], {\n34\t      stdio: ['ignore', 'pipe', 'pipe'],\n35\t      timeout: 8000,\n36\t    });\n37\t    return r.status === 0;\n38\t  } catch { return false; }\n39\t}\n40\t\n41\t// ── Detection Precedence Tests ─────────────────────────────────────────────────\n42\t\n43\ttest('detection_cloudbuild_takes_precedence', () => {\n44\t  const d = fixtureDir('cloudbuild');\n45\t  const r = detectCi(d);\n46\t  assert.equal(r.source, 'cloudbuild', 'Should detect cloudbuild source');\n47\t  assert.ok(r.commands.length > 0, 'Should extract commands from cloudbuild.yaml');\n48\t  // cloudbuild.yaml steps[].args are joined with spaces\n49\t  assert.ok(r.commands[0].includes('node'), 'First command should include \"node\"');\n50\t});\n51\t\n52\ttest('detection_workflows_when_no_cloudbuild', () => {\n53\t  const d = fixtureDir('workflows');\n54\t  // Ensure no cloudbuild.yaml in this fixture\n55\t  assert.ok(!fs.existsSync(path.join(d, 'cloudbuild.yaml')), 'Fixture must not have cloudbuild.yaml');\n56\t  const r = detectCi(d);\n57\t  assert.equal(r.source, 'workflows', 'Should detect workflows source');\n58\t  assert.ok(r.commands.length > 0, 'Should extract run commands from workflow yml');\n59\t});\n60\t\n61\ttest('detection_dockerfile_run_when_no_cloudbuild_or_workflows', () => {\n62\t  const d = fixtureDir('dockerfile-run');\n63\t  assert.ok(!fs.existsSync(path.join(d, 'cloudbuild.yaml')), 'Fixture must not have cloudbuild.yaml');\n64\t  assert.ok(!fs.existsSync(path.join(d, '.github')), 'Fixture must not have .github dir');\n65\t  const r = detectCi(d);\n66\t  assert.equal(r.source, 'dockerfile-run', 'Should detect dockerfile-run source');\n67\t  assert.ok(r.commands.length > 0, 'Should extract RUN lines from Dockerfile');\n68\t});\n69\t\n70\ttest('detection_package_scripts_fallback', () => {\n71\t  const d = fixtureDir('pkg-fallback');\n72\t  assert.ok(!fs.existsSync(path.join(d, 'cloudbuild.yaml')), 'Fixture must not have cloudbuild.yaml');\n73\t  assert.ok(!fs.existsSync(path.join(d, '.github')), 'Fixture must not have .github dir');\n74\t  assert.ok(!fs.existsSync(path.join(d, 'Dockerfile')), 'Fixture must not have Dockerfile');\n75\t  const r = detectCi(d);\n76\t  assert.equal(r.source, 'package-scripts', 'Should fall back to package-scripts');\n77\t  assert.ok(r.commands.length > 0, 'Should extract npm run scripts');\n78\t  // Order: build, typecheck, test\n79\t  assert.ok(r.commands[0].includes('build'), 'First script should be build');\n80\t  assert.ok(r.commands[1].includes('typecheck'), 'Second script should be typecheck');\n81\t  assert.ok(r.commands[2].includes('test'), 'Third script should be test');\n82\t});\n83\t\n84\ttest('detection_none_when_no_ci_artifacts', () => {\n85\t  // Use a temp dir with only an empty package.json (no scripts)\n86\t  const tmp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'gsd-t-ci-parity-none-'));\n87\t  try {\n88\t    fs.writeFileSync(path.join(tmp, 'package.json'), JSON.stringify({ name: 'test' }));\n89\t    const r = detectCi(tmp);\n90\t    assert.equal(r.source, 'none', 'Should return none when no CI config found');\n91\t    assert.deepEqual(r.commands, [], 'Should return empty commands array');\n92\t  } finally {\n93\t    fs.rmSync(tmp, { recursive: true, force: true });\n94\t  }\n95\t});\n96\t\n97\ttest('detection_precedence_strict_order_cloudbuild_beats_workflows', () => {\n98\t  // A fixture with both cloudbuild.yaml AND .github/workflows should use cloudbuild\n99\t  const tmp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'gsd-t-ci-parity-prec-'));\n100\t  try {\n101\t    fs.writeFileSync(path.join(tmp, 'cloudbuild.yaml'), [\n102\t      'steps:',\n103\t      \"  - name: 'node:18'\",\n104\t      \"    args: ['node', '-e', 'process.exit(0)']\",\n105\t    ].join('\\n'));\n106\t    const wfDir = path.join(tmp, '.github', 'workflows');\n107\t    fs.mkdirSync(wfDir, { recursive: true });\n108\t    fs.writeFileSync(path.join(wfDir, 'ci.yml'), [\n109\t      'name: CI',\n110\t      'on: [push]',\n111\t      'jobs:',\n112\t      '  build:',\n113\t      '    steps:',\n114\t      '      - run: echo workflows-step',\n115\t    ].join('\\n'));\n116\t    const r = detectCi(tmp);\n117\t    assert.equal(r.source, 'cloudbuild', 'cloudbuild must beat workflows in precedence');\n118\t  } finally {\n119\t    fs.rmSync(tmp, { recursive: true, force: true });\n120\t  }\n121\t});\n122\t\n123\t// ── Cache Clear Tests ──────────────────────────────────────────────────────────\n124\t\n125\ttest('cache_clear_removes_tsbuildinfo', () => {\n126\t  const tmp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'gsd-t-ci-parity-cache-'));\n127\t  try {\n128\t    // Plant a stale .tsbuildinfo file\n129\t    const staleFile = path.join(tmp, 'tsconfig.tsbuildinfo');\n130\t    fs.writeFileSync(staleFile, '{}');\n131\t    assert.ok(fs.existsSync(staleFile), 'Stale file must exist before clear');\n132\t    clearBuildCaches(tmp);\n133\t    assert.ok(!fs.existsSync(staleFile), 'Stale .tsbuildinfo must be removed after clear');\n134\t  } finally {\n135\t    fs.rmSync(tmp, { recursive: true, force: true });\n136\t  }\n137\t});\n138\t\n139\ttest('cache_clear_removes_node_modules_cache', () => {\n140\t  const tmp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'gsd-t-ci-parity-nm-'));\n141\t  try {\n142\t    const cacheDir = path.join(tmp, 'node_modules', '.cache');\n143\t    fs.mkdirSync(cacheDir, { recursive: true });\n144\t    fs.writeFileSync(path.join(cacheDir, 'something.json'), '{}');\n145\t    assert.ok(fs.existsSync(cacheDir), 'Cache dir must exist before clear');\n146\t    clearBuildCaches(tmp);\n147\t    assert.ok(!fs.existsSync(cacheDir), 'node_modules/.cache must be removed after clear');\n148\t  } finally {\n149\t    fs.rmSync(tmp, { recursive: true, force: true });\n150\t  }\n151\t});\n152\t\n153\ttest('cache_clear_removes_tsconfig_tsbuildinffile', () => {\n154\t  const tmp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'gsd-t-ci-parity-tscfg-'));\n155\t  try {\n156\t    // Plant a tsconfig.json with explicit tsBuildInfoFile\n157\t    const buildInfoPath = path.join(tmp, '.tsbuildinfo');\n158\t    fs.writeFileSync(buildInfoPath, '{\"version\":\"stale\"}');\n159\t    fs.writeFileSync(path.join(tmp, 'tsconfig.json'), JSON.stringify({\n160\t      compilerOptions: {\n161\t        incremental: true,\n162\t        tsBuildInfoFile: '.tsbuildinfo',\n163\t        noEmit: true,\n164\t      },\n165\t    }));\n166\t    assert.ok(fs.existsSync(buildInfoPath), 'tsBuildInfoFile must exist before clear');\n167\t    clearBuildCaches(tmp);\n168\t    assert.ok(!fs.existsSync(buildInfoPath), 'tsBuildInfoFile must be removed after clear');\n169\t  } finally {\n170\t    fs.rmSync(tmp, { recursive: true, force: true });\n171\t  }\n172\t});\n173\t\n174\t// ── Docker skip / unavailable Tests ──────────────────────────────────────────\n175\t\n176\ttest('no_dockerfile_skips_docker_non_failure', () => {\n177\t  const d = fixtureDir('pkg-fallback');\n178\t  // pkg-fallback has no Dockerfile — docker should be skipped, not a failure\n179\t  const r = runCiParity({ projectDir: d, timeoutMs: 10000 });\n180\t  assert.equal(r.dockerBuilt, false, 'dockerBuilt must be false when no Dockerfile');\n181\t  assert.equal(r.dockerSkippedReason, 'no-dockerfile', 'dockerSkippedReason must be no-dockerfile');\n182\t});\n183\t\n184\ttest('docker_unavailable_is_not_hard_failure', () => {\n185\t  // Use a temp dir with a Dockerfile but simulate docker-unavailable by\n186\t  // checking the path; we test the module logic via the return envelope shape.\n187\t  // This test validates the contract: docker-unavailable → non-failure.\n188\t  const tmp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'gsd-t-ci-parity-docker-'));\n189\t  try {\n190\t    fs.writeFileSync(path.join(tmp, 'Dockerfile'), 'FROM scratch\\n');\n191\t    fs.writeFileSync(path.join(tmp, 'package.json'), JSON.stringify({\n192\t      name: 'test', scripts: { build: 'node -e \"process.exit(0)\"' },\n193\t    }));\n194\t    // We can't easily simulate docker binary missing in a unit test without\n195\t    // PATH manipulation, so we test the no-dockerfile case and verify\n196\t    // the envelope shape is correct for the unavailable path via module internals.\n197\t    // The SC2 test covers docker-present behavior.\n198\t    // Assertion: when docker IS available, dockerSkippedReason is absent;\n199\t    // when absent (no Dockerfile), it is 'no-dockerfile'. The 'docker-unavailable'\n200\t    // path is exercised by the SC2 self-skip guard.\n201\t    const noDockerDir = fixtureDir('pkg-fallback');\n202\t    const r2 = runCiParity({ projectDir: noDockerDir, timeoutMs: 10000 });\n203\t    assert.equal(r2.dockerSkippedReason, 'no-dockerfile');\n204\t    assert.ok(typeof r2.ok === 'boolean', 'ok must be boolean');\n205\t  } finally {\n206\t    fs.rmSync(tmp, { recursive: true, force: true });\n207\t  }\n208\t});\n209\t\n210\t// ── runCiParity integration: fast no-op fixtures ───────────────────────────────\n211\t\n212\ttest('run_ci_parity_cloudbuild_commands_pass', () => {\n213\t  const r = runCiParity({ projectDir: fixtureDir('cloudbuild'), timeoutMs: 15000 });\n214\t  assert.equal(r.detectedSource, 'cloudbuild');\n215\t  assert.ok(r.commands.length > 0, 'Should have run commands');\n216\t  // All commands in this fixture are node no-ops → should pass\n217\t  const allOk = r.commands.every((c) => c.ok);\n218\t  assert.ok(allOk, `All cloudbuild commands should pass; got: ${JSON.stringify(r.commands)}`);\n219\t});\n220\t\n221\ttest('run_ci_parity_workflows_commands_pass', () => {\n222\t  const r = runCiParity({ projectDir: fixtureDir('workflows'), timeoutMs: 15000 });\n223\t  assert.equal(r.detectedSource, 'workflows');\n224\t  assert.ok(r.commands.length > 0, 'Should have run commands');\n225\t});\n226\t\n227\ttest('run_ci_parity_pkg_fallback_commands_pass', () => {\n228\t  const r = runCiParity({ projectDir: fixtureDir('pkg-fallback'), timeoutMs: 15000 });\n229\t  assert.equal(r.detectedSource, 'package-scripts');\n230\t  assert.ok(r.commands.length > 0);\n231\t  assert.ok(r.commands.every((c) => c.ok), `All pkg-fallback commands should pass; got: ${JSON.stringify(r.commands)}`);\n232\t});\n233\t\n234\ttest('run_ci_parity_none_returns_ok_true', () => {\n235\t  const tmp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'gsd-t-ci-parity-empty-'));\n236\t  try {\n237\t    // Empty dir → none source → ok:true\n238\t    const r = runCiParity({ projectDir: tmp, timeoutMs: 5000 });\n239\t    assert.equal(r.detectedSource, 'none');\n240\t    assert.ok(r.ok, 'none-detected should be ok:true');\n241\t    assert.ok(r.note, 'Should include a note for none-detected');\n242\t  } finally {\n243\t    fs.rmSync(tmp, { recursive: true, force: true });\n244\t  }\n245\t});\n246\t\n247\t// ── Envelope shape ────────────────────────────────────────────────────────────\n248\t\n249\ttest('envelope_shape_has_required_fields', () => {\n250\t  const r = runCiParity({ projectDir: fixtureDir('pkg-fallback'), timeoutMs: 10000 });\n251\t  assert.ok('ok' in r, 'envelope must have ok');\n252\t  assert.ok('detectedSource' in r, 'envelope must have detectedSource');\n253\t  assert.ok('commands' in r, 'envelope must have commands');\n254\t  assert.ok('dockerBuilt' in r, 'envelope must have dockerBuilt');\n255\t  assert.ok(Array.isArray(r.commands), 'commands must be array');\n256\t  for (const c of r.commands) {\n257\t    assert.ok('cmd' in c, 'command entry must have cmd');\n258\t    assert.ok('exitCode' in c, 'command entry must have exitCode');\n259\t    assert.ok('ok' in c, 'command entry must have ok');\n260\t  }\n261\t});\n262\t\n263\t// ── SC2: Planted regression test (docker-dependent, self-skips) ───────────────\n264\t\n265\ttest('SC2_planted_regression_docker_build_fails', { skip: !isDockerAvailable() ? 'No Docker daemon available — SC2 docker-dependent assertion skipped. Detection+cache-clear path tested unconditionally below.' : false }, async () => {\n266\t  const d = fixtureDir('planted-regression');\n267\t\n268\t  // First: unconditional assertions (detection + cache clear)\n269\t  const detected = detectCi(d);\n270\t  // planted-regression has Dockerfile → dockerfile-run source\n271\t  assert.equal(detected.source, 'dockerfile-run', 'SC2 fixture must detect dockerfile-run source');\n272\t\n273\t  // Plant the stale .tsbuildinfo back (in case a previous run removed it)\n274\t  const tsBuildInfoPath = path.join(d, '.tsbuildinfo');\n275\t  const staleContent = JSON.stringify({\n276\t    program: { fileNames: ['./src/index.ts'], fileInfos: [{ version: 'stale', signature: 'stale' }], options: {} },\n277\t    version: '4.9.5',\n278\t  });\n279\t  fs.writeFileSync(tsBuildInfoPath, staleContent);\n280\t  assert.ok(fs.existsSync(tsBuildInfoPath), 'Stale .tsbuildinfo must be present before test');\n281\t\n282\t  // When docker IS available: run the full parity check\n283\t  // This should remove the stale .tsbuildinfo AND run docker build which FAILS\n284\t  // because the Dockerfile runs npx tsc --noEmit and the src/index.ts has\n285\t  // a noImplicitAny violation.\n286\t  const r = runCiParity({ projectDir: d, timeoutMs: 180000 }); // 3 min for docker build\n287\t\n288\t  // Docker must have attempted to build\n289\t  assert.ok(\n290\t    r.dockerBuilt === false || r.dockerSkippedReason === undefined,\n291\t    'dockerBuilt should be false (failed) when docker runs'\n292\t  );\n293\t\n294\t  // ok must be false — regression was caught\n295\t  assert.equal(r.ok, false, 'SC2: docker build must fail → ok:false');\n296\t\n297\t  // Stale .tsbuildinfo must have been cleared before commands ran\n298\t  // (cache clear runs before commands, so even if docker build failed the file is gone)\n299\t  // Note: the .tsbuildinfo we planted must have been cleared\n300\t  // (runCiParity clears before running commands)\n301\t});\n302\t\n303\ttest('SC2_detection_and_cache_clear_unconditional', () => {\n304\t  // This portion of SC2 always runs regardless of Docker availability.\n305\t  const d = fixtureDir('planted-regression');\n306\t\n307\t  // Detection\n308\t  const r = detectCi(d);\n309\t  assert.equal(r.source, 'dockerfile-run', 'SC2 fixture must detect dockerfile-run');\n310\t  assert.ok(r.commands.length > 0, 'SC2 fixture must have commands');\n311\t\n312\t  // Plant stale .tsbuildinfo\n313\t  const staleFile = path.join(d, '.tsbuildinfo');\n314\t  fs.writeFileSync(staleFile, '{\"version\":\"stale-for-test\"}');\n315\t  assert.ok(fs.existsSync(staleFile), 'Stale file must exist before cache clear');\n316\t\n317\t  // Cache clear removes it\n318\t  clearBuildCaches(d);\n319\t  assert.ok(!fs.existsSync(staleFile), 'Cache clear must remove the stale .tsbuildinfo (SC2 anti-regression)');\n320\t});\n321\t\n322\t// ── CLI exit code tests ────────────────────────────────────────────────────────\n323\t\n324\ttest('cli_exit_0_on_ok_true', () => {\n325\t  const r = child_process.spawnSync(\n326\t    process.execPath,\n327\t    [path.join(__dirname, '..', 'bin', 'gsd-t-ci-parity.cjs'), '--json',\n328\t     '--project-dir', fixtureDir('pkg-fallback'), '--timeout-ms', '15000'],\n329\t    { encoding: 'utf8' }\n330\t  );\n331\t  assert.equal(r.status, 0, `Expected exit 0, got ${r.status}. stdout: ${r.stdout}`);\n332\t  const out = JSON.parse(r.stdout.trim());\n333\t  assert.equal(out.ok, true);\n334\t});\n335\t\n336\ttest('cli_json_output_has_correct_shape', () => {\n337\t  const r = child_process.spawnSync(\n338\t    process.execPath,\n339\t    [path.join(__dirname, '..', 'bin', 'gsd-t-ci-parity.cjs'), '--json',\n340\t     '--project-dir', fixtureDir('pkg-fallback'), '--timeout-ms', '15000'],\n341\t    { encoding: 'utf8' }\n342\t  );\n343\t  const out = JSON.parse(r.stdout.trim());\n344\t  assert.ok('ok' in out);\n345\t  assert.ok('detectedSource' in out);\n346\t  assert.ok('commands' in out);\n347\t  assert.ok('dockerBuilt' in out);\n348\t});\n349\t\n350\ttest('cli_exit_4_on_ok_false', () => {\n351\t  // Create a fixture that will fail: a command with non-zero exit\n352\t  const tmp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'gsd-t-ci-parity-fail-'));\n353\t  try {\n354\t    fs.writeFileSync(path.join(tmp, 'package.json'), JSON.stringify({\n355\t      name: 'test-fail',\n356\t      scripts: { build: 'node -e \"process.exit(1)\"' },\n357\t    }));\n358\t    const r = child_process.spawnSync(\n359\t      process.execPath,\n360\t      [path.join(__dirname, '..', 'bin', 'gsd-t-ci-parity.cjs'), '--json',\n361\t       '--project-dir', tmp, '--timeout-ms', '10000'],\n362\t      { encoding: 'utf8' }\n363\t    );\n364\t    assert.equal(r.status, 4, `Expected exit 4, got ${r.status}. stdout: ${r.stdout}`);\n365\t    const out = JSON.parse(r.stdout.trim());\n366\t    assert.equal(out.ok, false);\n367\t  } finally {\n368\t    fs.rmSync(tmp, { recursive: true, force: true });\n369\t  }\n370\t});\n371\t\n372\ttest('cli_help_exits_0', () => {\n373\t  const r = child_process.spawnSync(\n374\t    process.execPath,\n375\t    [path.join(__dirname, '..', 'bin', 'gsd-t-ci-parity.cjs'), '--help'],\n376\t    { encoding: 'utf8' }\n377\t  );\n378\t  assert.equal(r.status, 0, `--help should exit 0, got ${r.status}`);\n379\t});\n380\t"}]},"parent_tool_use_id":"toolu_01QUFQvtmXATKW23tz74hyrx","session_id":"58ad06dd-2644-4e21-9536-13779b8ab76f","uuid":"024bca94-5043-430c-a07a-0984ab5e37e3","timestamp":"2026-05-18T21:55:53.841Z","subagent_type":"general-purpose","task_description":"Fix D2 QA test gaps"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NbxXgjitdKhPx5KsM6dEvE","type":"tool_result","content":"1\t#!/usr/bin/env node\n2\t'use strict';\n3\t\n4\t/**\n5\t * GSD-T ci-parity (M57 D2)\n6\t *\n7\t * Reproduces a project's actual CI build locally instead of relying on\n8\t * potentially warm-cache local tsc/test parity.\n9\t *\n10\t * Auto-detects CI config via locked detection precedence (user decision — do\n11\t * NOT reorder): cloudbuild.yaml → .github/workflows/*.yml → Dockerfile RUN →\n12\t * package.json scripts (build, typecheck, test) → none.\n13\t *\n14\t * Clears build caches before running detected commands so stale incremental\n15\t * artifacts cannot mask regressions (the TimeTracking v1.10.12 SC2 failure\n16\t * class: ~8 noImplicitAny errors passed warm-cache local tsc, failed CI cold\n17\t * build).\n18\t *\n19\t * When a Dockerfile is present, runs a real `docker build` — presence is the\n20\t * sole trigger; no opt-in flag (locked user decision).\n21\t *\n22\t * Contract: .gsd-t/contracts/ci-parity-contract.md v1.0.0 STABLE\n23\t *\n24\t * Parse limits (no external YAML lib; minimal line/regex scanning):\n25\t *   - cloudbuild.yaml: only reads `args:` array elements under `steps:`.\n26\t *     Multi-line folded/block scalars are not supported. Only simple\n27\t *     `args: [...]` one-liner arrays or `- 'val'` list forms are handled.\n28\t *   - .github/workflows/*.yml: only reads `run:` lines from the FIRST job's\n29\t *     steps. Multi-line pipe/fold blocks (`run: |`) capture only the first\n30\t *     continuation line. `uses:` steps (no `run:`) are skipped.\n31\t *   - Dockerfile: reads `RUN` lines (single-line only; backslash-continuations\n32\t *     are joined into one command).\n33\t *   These limits are intentional trade-offs to keep the module at zero\n34\t *   external runtime deps.\n35\t */\n36\t\n37\tconst fs = require('fs');\n38\tconst path = require('path');\n39\tconst child_process = require('child_process');\n40\t\n41\tconst DEFAULT_TIMEOUT_MS = 120_000;\n42\t\n43\t// ── Detection ─────────────────────────────────────────────────────────────────\n44\t\n45\t/** Parse cloudbuild.yaml steps[].args → array of command strings. */\n46\tfunction detectCloudbuild(projectDir) {\n47\t  const f = path.join(projectDir, 'cloudbuild.yaml');\n48\t  if (!fs.existsSync(f)) return null;\n49\t  const lines = fs.readFileSync(f, 'utf8').split('\\n');\n50\t  const cmds = [];\n51\t  let inArgs = false;\n52\t  let argParts = [];\n53\t\n54\t  for (const raw of lines) {\n55\t    const line = raw.trimEnd();\n56\t    // Inline array: `    args: ['node', '-e', '...']`\n57\t    const inlineM = line.match(/^\\s+args:\\s*\\[(.+)\\]/);\n58\t    if (inlineM) {\n59\t      const cmd = inlineM[1]\n60\t        .split(',')\n61\t        .map((t) => t.trim().replace(/^['\"]|['\"]$/g, ''))\n62\t        .filter(Boolean)\n63\t        .join(' ');\n64\t      if (cmd) cmds.push(cmd);\n65\t      inArgs = false;\n66\t      argParts = [];\n67\t      continue;\n68\t    }\n69\t    // Start of args block: `    args:`\n70\t    if (/^\\s+args:\\s*$/.test(line)) {\n71\t      inArgs = true;\n72\t      argParts = [];\n73\t      continue;\n74\t    }\n75\t    if (inArgs) {\n76\t      // List item under args\n77\t      const itemM = line.match(/^\\s+-\\s+['\"]?(.+?)['\"]?\\s*$/);\n78\t      if (itemM) {\n79\t        argParts.push(itemM[1]);\n80\t        continue;\n81\t      }\n82\t      // Not a list item → end of args block\n83\t      if (argParts.length) {\n84\t        cmds.push(argParts.join(' '));\n85\t        argParts = [];\n86\t      }\n87\t      inArgs = false;\n88\t    }\n89\t  }\n90\t  if (inArgs && argParts.length) cmds.push(argParts.join(' '));\n91\t  return cmds.length ? cmds : [];\n92\t}\n93\t\n94\t/** Parse first job's steps[].run from .github/workflows/*.yml. */\n95\tfunction detectWorkflows(projectDir) {\n96\t  const wfDir = path.join(projectDir, '.github', 'workflows');\n97\t  if (!fs.existsSync(wfDir)) return null;\n98\t  const files = fs.readdirSync(wfDir).filter((f) => /\\.ya?ml$/.test(f));\n99\t  if (!files.length) return null;\n100\t  const lines = fs.readFileSync(path.join(wfDir, files[0]), 'utf8').split('\\n');\n101\t  const cmds = [];\n102\t  let inJobs = false;\n103\t  let inSteps = false;\n104\t  let firstJobDone = false;\n105\t  let jobDepth = 0;\n106\t  let pendingRun = null;\n107\t\n108\t  for (const raw of lines) {\n109\t    const line = raw.trimEnd();\n110\t    if (/^jobs:/.test(line)) { inJobs = true; continue; }\n111\t    if (!inJobs) continue;\n112\t    if (firstJobDone) continue;\n113\t\n114\t    // Detect first-job boundary (4-space indent key)\n115\t    if (/^  \\w[\\w-]*:/.test(line)) { jobDepth++; if (jobDepth > 1) { firstJobDone = true; continue; } }\n116\t    if (/^\\s+steps:/.test(line)) { inSteps = true; continue; }\n117\t    if (!inSteps) continue;\n118\t\n119\t    // Inline run: `      - run: cmd`\n120\t    const inlineRunM = line.match(/^\\s+-\\s+run:\\s+(.+)$/);\n121\t    if (inlineRunM) { cmds.push(inlineRunM[1].trim()); pendingRun = null; continue; }\n122\t    // Block run marker: `        run: |` or `        run: >`\n123\t    const blockRunM = line.match(/^\\s+run:\\s*[|>]?\\s*$/);\n124\t    if (blockRunM) { pendingRun = true; continue; }\n125\t    // Inline run value: `        run: cmd`\n126\t    const plainRunM = line.match(/^\\s+run:\\s+(.+)$/);\n127\t    if (plainRunM && !blockRunM) { cmds.push(plainRunM[1].trim()); pendingRun = null; continue; }\n128\t    // Continuation line for block run (indented more than run:)\n129\t    if (pendingRun) {\n130\t      const contM = line.match(/^\\s{10,}(.+)$/);\n131\t      if (contM) { cmds.push(contM[1].trim()); pendingRun = null; continue; }\n132\t      if (line.trim() === '') continue;\n133\t      pendingRun = null;\n134\t    }\n135\t  }\n136\t  return cmds.length ? cmds : [];\n137\t}\n138\t\n139\t/** Parse RUN lines from a Dockerfile (backslash-continuations joined). */\n140\tfunction detectDockerfileRun(projectDir) {\n141\t  const f = path.join(projectDir, 'Dockerfile');\n142\t  if (!fs.existsSync(f)) return null;\n143\t  const lines = fs.readFileSync(f, 'utf8').split('\\n');\n144\t  const cmds = [];\n145\t  let buf = '';\n146\t\n147\t  for (const raw of lines) {\n148\t    const line = raw.trimEnd();\n149\t    if (/^RUN\\s+/.test(line)) {\n150\t      buf = line.replace(/^RUN\\s+/, '').replace(/\\\\$/, '').trim();\n151\t    } else if (buf && /^\\s/.test(line)) {\n152\t      buf += ' ' + line.replace(/\\\\$/, '').trim();\n153\t    } else {\n154\t      if (buf) { cmds.push(buf); buf = ''; }\n155\t    }\n156\t  }\n157\t  if (buf) cmds.push(buf);\n158\t  return cmds.length ? cmds : [];\n159\t}\n160\t\n161\t/** Extract package.json scripts: build, typecheck, test (in that order). */\n162\tfunction detectPackageScripts(projectDir) {\n163\t  const f = path.join(projectDir, 'package.json');\n164\t  if (!fs.existsSync(f)) return null;\n165\t  let pkg;\n166\t  try { pkg = JSON.parse(fs.readFileSync(f, 'utf8')); } catch { return null; }\n167\t  const scripts = (pkg && pkg.scripts) || {};\n168\t  const ORDER = ['build', 'typecheck', 'test'];\n169\t  const found = ORDER.filter((k) => scripts[k]);\n170\t  if (!found.length) return null;\n171\t  return found.map((k) => `npm run ${k}`);\n172\t}\n173\t\n174\t/**\n175\t * Detect CI source and return { source, commands }.\n176\t * Precedence: cloudbuild → workflows → dockerfile-run → package-scripts → none.\n177\t */\n178\tfunction detectCi(projectDir) {\n179\t  const cb = detectCloudbuild(projectDir);\n180\t  if (cb !== null) return { source: 'cloudbuild', commands: cb };\n181\t\n182\t  const wf = detectWorkflows(projectDir);\n183\t  if (wf !== null) return { source: 'workflows', commands: wf };\n184\t\n185\t  const df = detectDockerfileRun(projectDir);\n186\t  if (df !== null) return { source: 'dockerfile-run', commands: df };\n187\t\n188\t  const ps = detectPackageScripts(projectDir);\n189\t  if (ps !== null) return { source: 'package-scripts', commands: ps };\n190\t\n191\t  return { source: 'none', commands: [] };\n192\t}\n193\t\n194\t// ── Cache clearing ─────────────────────────────────────────────────────────────\n195\t\n196\tfunction collectFiles(dir, pred, depth, out) {\n197\t  if (depth <= 0) return;\n198\t  let entries;\n199\t  try { entries = fs.readdirSync(dir, { withFileTypes: true }); } catch { return; }\n200\t  for (const e of entries) {\n201\t    const full = path.join(dir, e.name);\n202\t    if (e.isDirectory()) {\n203\t      if (e.name === 'node_modules') continue;\n204\t      collectFiles(full, pred, depth - 1, out);\n205\t    } else if (pred(e.name)) {\n206\t      out.push(full);\n207\t    }\n208\t  }\n209\t}\n210\t\n211\t/** Parse tsBuildInfoFile and outDir from tsconfig*.json files. */\n212\tfunction parseTsconfigArtifacts(projectDir) {\n213\t  const paths = [];\n214\t  let entries;\n215\t  try { entries = fs.readdirSync(projectDir); } catch { return paths; }\n216\t  for (const name of entries) {\n217\t    if (!/^tsconfig.*\\.json$/.test(name)) continue;\n218\t    let cfg;\n219\t    try { cfg = JSON.parse(fs.readFileSync(path.join(projectDir, name), 'utf8')); } catch { continue; }\n220\t    const opts = (cfg && cfg.compilerOptions) || {};\n221\t    if (opts.tsBuildInfoFile) {\n222\t      paths.push(path.resolve(projectDir, opts.tsBuildInfoFile));\n223\t    }\n224\t    if (opts.outDir) {\n225\t      paths.push(path.resolve(projectDir, opts.outDir));\n226\t    }\n227\t  }\n228\t  return paths;\n229\t}\n230\t\n231\tfunction removePath(p) {\n232\t  try {\n233\t    const st = fs.statSync(p);\n234\t    if (st.isDirectory()) fs.rmSync(p, { recursive: true, force: true });\n235\t    else fs.unlinkSync(p);\n236\t  } catch { /* best-effort */ }\n237\t}\n238\t\n239\t/** Clear build caches before running detected commands (mandatory). */\n240\tfunction clearBuildCaches(projectDir) {\n241\t  // 1. Remove all *.tsbuildinfo files recursively\n242\t  const tsBuildInfoFiles = [];\n243\t  collectFiles(projectDir, (name) => name.endsWith('.tsbuildinfo'), 6, tsBuildInfoFiles);\n244\t  for (const f of tsBuildInfoFiles) removePath(f);\n245\t\n246\t  // 2. Remove node_modules/.cache\n247\t  removePath(path.join(projectDir, 'node_modules', '.cache'));\n248\t\n249\t  // 3. Remove tsconfig-referenced outDir / tsBuildInfoFile (best-effort)\n250\t  for (const p of parseTsconfigArtifacts(projectDir)) removePath(p);\n251\t}\n252\t\n253\t// ── Command runner ─────────────────────────────────────────────────────────────\n254\t\n255\t/** Run a single shell command with bounded timeout. Returns {cmd, exitCode, ok, output}. */\n256\tfunction runCommand(cmd, projectDir, timeoutMs) {\n257\t  let result;\n258\t  try {\n259\t    result = child_process.spawnSync('sh', ['-c', cmd], {\n260\t      cwd: projectDir,\n261\t      timeout: timeoutMs,\n262\t      encoding: 'utf8',\n263\t      stdio: ['ignore', 'pipe', 'pipe'],\n264\t    });\n265\t  } catch (err) {\n266\t    return { cmd, exitCode: 1, ok: false, output: String(err) };\n267\t  }\n268\t  const exitCode = result.status != null ? result.status : 1;\n269\t  return { cmd, exitCode, ok: exitCode === 0, output: (result.stdout || '') + (result.stderr || '') };\n270\t}\n271\t\n272\t// ── Docker ─────────────────────────────────────────────────────────────────────\n273\t\n274\t/** Check whether the `docker` binary is available on PATH. */\n275\tfunction dockerAvailable() {\n276\t  try {\n277\t    const r = child_process.spawnSync('docker', ['--version'], {\n278\t      stdio: ['ignore', 'pipe', 'pipe'],\n279\t      timeout: 5000,\n280\t    });\n281\t    return r.status === 0;\n282\t  } catch { return false; }\n283\t}\n284\t\n285\t/**\n286\t * Run `docker build` in projectDir with a bounded timeout.\n287\t * Returns { ok, exitCode, output }.\n288\t */\n289\tfunction runDockerBuild(projectDir, timeoutMs) {\n290\t  const tag = `gsd-t-ci-parity-${Date.now()}`;\n291\t  let result;\n292\t  try {\n293\t    result = child_process.spawnSync(\n294\t      'docker', ['build', '--no-cache', '-t', tag, '.'],\n295\t      {\n296\t        cwd: projectDir,\n297\t        timeout: timeoutMs,\n298\t        encoding: 'utf8',\n299\t        stdio: ['ignore', 'pipe', 'pipe'],\n300\t      }\n301\t    );\n302\t  } catch (err) {\n303\t    return { ok: false, exitCode: 1, output: String(err) };\n304\t  }\n305\t  // Best-effort cleanup of created image\n306\t  try {\n307\t    child_process.spawnSync('docker', ['rmi', '-f', tag], {\n308\t      stdio: 'ignore', timeout: 10000,\n309\t    });\n310\t  } catch { /* ignore */ }\n311\t  const exitCode = result.status != null ? result.status : 1;\n312\t  return { ok: exitCode === 0, exitCode, output: (result.stdout || '') + (result.stderr || '') };\n313\t}\n314\t\n315\t// ── Public API ─────────────────────────────────────────────────────────────────\n316\t\n317\t/**\n318\t * Run CI parity check for a project.\n319\t *\n320\t * @param {object} opts\n321\t * @param {string} opts.projectDir\n322\t * @param {number} [opts.timeoutMs]\n323\t * @returns {{ ok: boolean, detectedSource: string, commands: Array, dockerBuilt: boolean, dockerSkippedReason?: string, note?: string }}\n324\t */\n325\tfunction runCiParity(opts) {\n326\t  const projectDir = (opts && opts.projectDir) || process.cwd();\n327\t  const timeoutMs = (opts && opts.timeoutMs) || DEFAULT_TIMEOUT_MS;\n328\t\n329\t  const { source, commands } = detectCi(projectDir);\n330\t\n331\t  // No CI config found — not a failure\n332\t  if (source === 'none') {\n333\t    const hasDockerfile = fs.existsSync(path.join(projectDir, 'Dockerfile'));\n334\t    const dockerResult = hasDockerfile\n335\t      ? runDockerStep(projectDir, timeoutMs)\n336\t      : { dockerBuilt: false, dockerSkippedReason: 'no-dockerfile' };\n337\t    return {\n338\t      ok: !dockerResult.dockerFailed,\n339\t      detectedSource: 'none',\n340\t      commands: [],\n341\t      ...dockerResult,\n342\t      note: 'No CI config detected (no cloudbuild.yaml, .github/workflows, Dockerfile RUN lines, or package.json scripts)',\n343\t    };\n344\t  }\n345\t\n346\t  // Clear caches before running anything\n347\t  clearBuildCaches(projectDir);\n348\t\n349\t  // Run all detected commands\n350\t  const commandResults = [];\n351\t  let allOk = true;\n352\t  for (const cmd of commands) {\n353\t    const r = runCommand(cmd, projectDir, timeoutMs);\n354\t    commandResults.push({ cmd: r.cmd, exitCode: r.exitCode, ok: r.ok });\n355\t    if (!r.ok) allOk = false;\n356\t  }\n357\t\n358\t  // Docker step (presence-triggered, not a failure if docker unavailable)\n359\t  const hasDockerfile = fs.existsSync(path.join(projectDir, 'Dockerfile'));\n360\t  const dockerResult = hasDockerfile\n361\t    ? runDockerStep(projectDir, timeoutMs)\n362\t    : { dockerBuilt: false, dockerSkippedReason: 'no-dockerfile' };\n363\t\n364\t  if (dockerResult.dockerFailed) allOk = false;\n365\t\n366\t  const envelope = {\n367\t    ok: allOk,\n368\t    detectedSource: source,\n369\t    commands: commandResults,\n370\t    dockerBuilt: dockerResult.dockerBuilt,\n371\t  };\n372\t  if (dockerResult.dockerSkippedReason) envelope.dockerSkippedReason = dockerResult.dockerSkippedReason;\n373\t  if (!allOk && commands.length === 0) envelope.note = 'No commands detected';\n374\t  return envelope;\n375\t}\n376\t\n377\t/**\n378\t * Run docker build step (T3 logic).\n379\t * Returns { dockerBuilt, dockerFailed?, dockerSkippedReason? }\n380\t */\n381\tfunction runDockerStep(projectDir, timeoutMs) {\n382\t  if (!dockerAvailable()) {\n383\t    return { dockerBuilt: false, dockerSkippedReason: 'docker-unavailable', dockerFailed: false };\n384\t  }\n385\t  const r = runDockerBuild(projectDir, timeoutMs);\n386\t  return {\n387\t    dockerBuilt: r.ok,\n388\t    dockerFailed: !r.ok,\n389\t  };\n390\t}\n391\t\n392\tmodule.exports = { runCiParity, detectCi, clearBuildCaches };\n393\t\n394\t// ── CLI entry ──────────────────────────────────────────────────────────────────\n395\t\n396\tif (require.main === module) {\n397\t  const argv = process.argv.slice(2);\n398\t  let jsonMode = false;\n399\t  let projectDir = process.cwd();\n400\t  let timeoutMs = DEFAULT_TIMEOUT_MS;\n401\t\n402\t  for (let i = 0; i < argv.length; i++) {\n403\t    const a = argv[i];\n404\t    if (a === '--json') { jsonMode = true; continue; }\n405\t    if (a === '--project-dir' && argv[i + 1]) { projectDir = argv[++i]; continue; }\n406\t    if (a === '--timeout-ms' && argv[i + 1]) { timeoutMs = Number(argv[++i]); continue; }\n407\t    if (a === '--help' || a === '-h') {\n408\t      process.stdout.write(\n409\t        'Usage: gsd-t ci-parity [--project-dir <dir>] [--timeout-ms <ms>] [--json]\\n' +\n410\t        'Exit 0 = all CI commands + docker build passed\\n' +\n411\t        'Exit 4 = failure\\n' +\n412\t        'Exit 2 = usage error\\n'\n413\t      );\n414\t      process.exit(0);\n415\t    }\n416\t  }\n417\t\n418\t  let result;\n419\t  try {\n420\t    result = runCiParity({ projectDir, timeoutMs });\n421\t  } catch (err) {\n422\t    if (jsonMode) {\n423\t      process.stdout.write(JSON.stringify({ ok: false, error: String(err) }) + '\\n');\n424\t    } else {\n425\t      process.stderr.write('ci-parity error: ' + String(err) + '\\n');\n426\t    }\n427\t    process.exit(4);\n428\t  }\n429\t\n430\t  if (jsonMode) {\n431\t    process.stdout.write(JSON.stringify(result) + '\\n');\n432\t  } else {\n433\t    const status = result.ok ? 'PASS' : 'FAIL';\n434\t    process.stdout.write(`[ci-parity] ${status} detectedSource=${result.detectedSource}\\n`);\n435\t    for (const c of result.commands) {\n436\t      process.stdout.write(`  [${c.ok ? 'ok' : 'FAIL'}] ${c.cmd} (exit ${c.exitCode})\\n`);\n437\t    }\n438\t    if (result.dockerBuilt) {\n439\t      process.stdout.write('  [ok] docker build\\n');\n440\t    } else if (result.dockerSkippedReason) {\n441\t      process.stdout.write(`  [skip] docker build: ${result.dockerSkippedReason}\\n`);\n442\t    } else if (!result.dockerBuilt) {\n443\t      process.stdout.write('  [FAIL] docker build\\n');\n444\t    }\n445\t    if (result.note) process.stdout.write(`  note: ${result.note}\\n`);\n446\t  }\n447\t\n448\t  process.exit(result.ok ? 0 : 4);\n449\t}\n450\t"}]},"parent_tool_use_id":"toolu_01QUFQvtmXATKW23tz74hyrx","session_id":"58ad06dd-2644-4e21-9536-13779b8ab76f","uuid":"673701df-2797-4ce7-886c-11f68ebace7f","timestamp":"2026-05-18T21:55:54.033Z","subagent_type":"general-purpose","task_description":"Fix D2 QA test gaps"}
