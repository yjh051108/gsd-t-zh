{
  "name": "gsd-t-zh",
  "version": "5.1.13",
  "description": "GSD-T 中文适配版: 54 个中文 slash 命令 + 第三方模型兼容 (Stepfun 代理) — 基于 Tekyz-Inc/get-stuff-done-teams v5.1.13",
  "author": "yjh051108",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yjh051108/gsd-t-zh.git"
  },
  "homepage": "https://github.com/yjh051108/gsd-t-zh#readme",
  "bugs": {
    "url": "https://github.com/yjh051108/gsd-t-zh/issues"
  },
  "keywords": [
    "claude-code",
    "gsd",
    "chinese",
    "zh-CN",
    "ai-development",
    "agent-teams",
    "contract-driven-development",
    "slash-commands",
    "stepfun",
    "third-party-model"
  ],
  "main": "bin/gsd-t.js",
  "bin": {
    "gsd-t": "bin/gsd-t.js",
    "gsd-t-zh": "bin/gsd-t.js"
  },
  "scripts": {
    "pretest": "node -e \"const fs=require('fs');for(const f of ['.gsd-t/graph.db','.gsd-t/graph.db-wal','.gsd-t/graph.db-shm']){try{if(fs.existsSync(f))fs.renameSync(f,f+'.testbak')}catch{}}\"",
    "test": "node --test",
    "posttest": "node -e \"const fs=require('fs');for(const f of ['.gsd-t/graph.db','.gsd-t/graph.db-wal','.gsd-t/graph.db-shm']){try{if(fs.existsSync(f+'.testbak'))fs.renameSync(f+'.testbak',f)}catch{}}\"",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "prepublishOnly": "npm test"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "graphology": "^0.26.0",
    "kuzu": "^0.11.3"
  },
  "files": [
    "bin/",
    "commands/",
    "scripts/",
    "templates/",
    "examples/",
    "docs/",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.23.2",
    "tree-sitter-python": "^0.21.0"
  }
}
