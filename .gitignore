# OS
.DS_Store
Thumbs.db
desktop.ini

# Temp files
.tmp.driveupload/
.gsd-t/dashboard.pid
*.pdf

# Editor
.vscode/
.idea/
*.swp
*.swo

# Node
node_modules/

# GSD-T heartbeat telemetry (session-specific, may contain sensitive data)
.gsd-t/heartbeat-*.jsonl

# GSD-T M43 D1 in-session token-usage sink (session-specific, regeneratable
# from the Claude Code transcript — contains per-turn session_id / turn_id)
.gsd-t/metrics/token-usage.jsonl

# GSD-T M90 arch-trigger instrumentation sink — transient, run-accumulated measurement
# data the R-FAIL-2 verify gate reads run-scoped. MUST NOT be committed: a tracked
# append-only sink makes the fail-closed gate permanently stuck-FAIL once any
# provenByAdversaryOnly:true record lands (Red Team CRITICAL, M90 verify fix-cycle 2).
.gsd-t/metrics/arch-trigger-events.jsonl

# GSD-T M90 loop-ledger state — transient runtime cycle counts per debug run. MUST NOT be
# committed: a tracked cumulative counter leaks cross-run state into clones and can re-arm the
# R-FAIL-3 fail-closed gate (Red Team MEDIUM, M90 verify fix-cycle 5).
.gsd-t/loop-ledger-state.json

# GSD-T M43 D1 hook-probe payloads (raw Stop/SessionEnd/PostToolUse captures,
# session-specific — contain session_id + transcript_path)
.gsd-t/.hook-probe/

# GSD-T M43 D1 in-session capture cursor (per-session idempotence state)
.gsd-t/.in-session-cursor.json

# GSD-T graph index (auto-generated, project-specific)
.gsd-t/graph/
# M94 SQLite graph store (D1/D3 store path; WAL/SHM siblings)
.gsd-t/graph.db
.gsd-t/graph.db-wal
.gsd-t/graph.db-shm

# GSD-T context meter (session-specific runtime state)
.gsd-t/.context-meter-state.json
.gsd-t/context-meter.log

# GSD-T watch-progress state (session-specific runtime state — M39 D2)
.gsd-t/.watch-state/

# Claude Code internal directories
.claude/worktrees/
.claude/settings.local.json

# Windows null device artifact
nul

# GSD-T context meter state file (session state — do not commit)
# Note: legitimate `.cjs` source files under bin/ ARE tracked; only the
# per-session state artifact should be ignored.
bin/context-meter-state.cjs
.gsd-t/.archive-migration-v1
.gsd-t/.task-counter-retired-v1

# GSD-T M55 D4 context briefs (per-spawn ephemera, regenerated by
# bin/gsd-t-context-brief.cjs — never committed)
.gsd-t/briefs/

# GSD-T M67 scan document-phase pre-edit backups (safety net only, not versioned)
.gsd-t/scan/.doc-backup/

# GSD-T M55 D5 verify-gate raw worker output (per-run; the LLM judge
# sees the ≤500-token summary in the envelope — never these files)
.gsd-t/verify-gate/

# GSD-T M58 test-data ledger (per-run; written by Playwright fixtures,
# swept by gsd-t-verify Step 4.5 — never committed)
.gsd-t/test-data-ledger.jsonl

# GSD-T runtime noise — append-only event streams, headless-spawn logs,
# session transcripts, supervisor state, recovery checkpoints. Future
# files of these classes are ignored; historical entries that were
# committed prior to this rule remain tracked (no `git rm --cached`).
.claude/scheduled_tasks.lock
.claude/settings.local.json.bak*
.gsd-t/.unattended/
.gsd-t/headless-*.log
.gsd-t/headless-sessions/
.gsd-t/events/
.gsd-t/transcripts/
.gsd-t/continue-here-*.md
.gsd-t/dashboard.log
.gsd-t/run.log
